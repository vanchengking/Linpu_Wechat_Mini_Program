page {
  height: 100%;
  width: 100%;
  padding-bottom: 100rpx;
}

/* 调整底部导航栏样式 */
.tabbar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 999;
  height: 180rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #e0e0e0;
  /* 添加内边距 */
  padding: 20rpx 0;
}

/* 调整页面内容区域，避免被底部导航栏遮挡 */
.page-content {
  min-height: calc(100vh - 100rpx);
  padding-bottom: 100rpx;
}

/* 通用样式 */
page, view, text, image {
  box-sizing: border-box;
}

page {
  margin: 0;
  padding: 0;
}

/* 页面基础样式 */
.container {
  min-height: 100vh;
  width: 100%;
}

/* ========== 页面进入过渡动画（只作用于容器，不破坏fixed定位） ========== */
.container {
  animation: pageIn 0.3s ease-out both;
}

@keyframes pageIn {
  from {
    opacity: 0;
    transform: translateY(12rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 通用按钮样式 */
.btn {
  padding: 20rpx 40rpx;
  border-radius: 10rpx;
  text-align: center;
  font-size: 28rpx;
  border: none;
  outline: none;
}

.btn-primary {
  background-color: #fcf7e3;
  color: white;
}

.btn-secondary {
  background-color: #f0f0f0;
  color: #333;
}

/* 通用卡片样式 */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

/* 文本样式 */
.text-center {
  text-align: center;
}

.text-left {
  text-align: left;
}

.text-right {
  text-align: right;
}

/* 布局样式 */
.flex {
  display: flex;
}

.flex-column {
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 间距样式 */
.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 浮窗按钮样式 */
.float-chat-btn {
  position: fixed;
  right: 50rpx;
  bottom: 100rpx;
  width: 90rpx;
  height: 90rpx;
  background-color: #fff;
  border-radius: 50%;
  border: 3rpx solid #D4AF37;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 99999;
  transition: all 0.3s ease;
  pointer-events: auto;
  overflow: hidden;
}

.float-chat-btn:active {
  transform: scale(0.9);
}

/* 图片严格限制在圆形容器内 */
.float-chat-icon {
  width: 70rpx;
  height: 70rpx;
  pointer-events: none;
}

/* 图片加载占位（仅对需要骨架屏的类生效） */
.bg-image, .bg-img, .bg, .bg-image {
  background-color: #f5f0e8;
  min-height: 200rpx;
}

/* 商品图片/卡片图片 加载中骨架效果 */
.product-img, .card-icon, .swiper-image, .slide-image, .map-bg, .map-img {
  background: linear-gradient(90deg, #f0ece0 25%, #faf7f0 50%, #f0ece0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  min-height: 200rpx;
}

/* 人物图标加载中 */
.character, .npc-icon {
  background-color: rgba(245, 240, 232, 0.6);
}

/* 骨架屏微光动画 */
@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}