.game-container {
  width: 100vw;
  height: 100vh;
  background-color: #f4e8d4;
  position: relative;
  overflow: hidden;
}

.game-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.4;
  z-index: 0;
}

.game-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(244, 232, 212, 0.2) 0%, rgba(244, 232, 212, 0.8) 100%);
  z-index: 1;
}

.phase1, .phase2 {
  position: relative;
  z-index: 2;
}

.score-panel-wrap {
  position: absolute;
  top: 30rpx;
  right: 20rpx;
  z-index: 100;
}

.phase1 {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 220rpx; /* 增加顶部边距，避开计分板 */
}

.target-word-display {
  background: rgba(255,255,255,0.8);
  padding: 10px 30px;
  border-radius: 20px;
  display: flex;
  align-items: center;
  margin-bottom: 20px;
  box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.hint-text {
  font-size: 18px;
  color: #333;
}

.target-char {
  font-size: 36px;
  font-weight: bold;
  color: #8b0000;
  font-family: "KaiTi", "SimSun", serif;
}

.combine-area {
  width: 200px;
  height: 200px;
  background: rgba(255,255,255,0.9);
  border: 4px solid #8b4513;
  position: relative;
  margin-top: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: inset 0 0 10px rgba(0,0,0,0.2);
}

.slot {
  width: 100%;
  height: 100%;
  border: 1px dashed #ccc;
  position: absolute;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 80px;
  font-family: "KaiTi", "SimSun", serif;
  color: #333;
}

.slot.filled {
  border: none;
}

.parts-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.part-item {
  position: absolute;
  width: 60px;
  height: 60px;
  background: #fff8dc;
  border: 2px solid #8b4513;
  border-radius: 8px;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 36px;
  font-family: "KaiTi", "SimSun", serif;
  color: #333;
  box-shadow: 2px 2px 5px rgba(0,0,0,0.2);
  pointer-events: auto;
  user-select: none;
  transform: translate(-50%, -50%);
}

.part-item.used {
  opacity: 0;
  pointer-events: none;
}

.phase2 {
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20px;
  box-sizing: border-box;
}

.quiz-card {
  width: 100%;
  background: rgba(255,255,255,0.95);
  border-radius: 12px;
  padding: 30px 20px;
  box-shadow: 0 10px 20px rgba(0,0,0,0.2);
  border: 2px solid #d2b48c;
}

.question-text {
  font-size: 20px;
  color: #333;
  margin-bottom: 30px;
  line-height: 1.5;
  font-weight: bold;
}

.options-container {
  display: flex;
  flex-direction: column;
  gap: 15px;
}

.option-item {
  background: #fdf5e6;
  border: 1px solid #deb887;
  padding: 15px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
}

.option-item.correct {
  background: #e8f5e9;
  border-color: #4caf50;
}

.option-item.wrong {
  background: #ffebee;
  border-color: #f44336;
}

.opt-label {
  font-size: 18px;
  font-weight: bold;
  color: #8b4513;
  margin-right: 15px;
  width: 30px;
  text-align: center;
}

.opt-text {
  font-size: 16px;
  color: #555;
  flex: 1;
}

/* 引导层样式 */
.tutorial-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  backdrop-filter: blur(5px);
}

.tutorial-content {
  width: 85%;
  background: #fff;
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.3);
  position: relative;
}

.npc-portrait {
  width: 200rpx;
  height: 200rpx;
  margin-top: -120rpx;
  background: #fff;
  border-radius: 50%;
  border: 6rpx solid #8B2323;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.2);
}

.speech-bubble {
  background: #fdf6ec;
  border: 2rpx solid #e6a23c;
  padding: 20rpx;
  border-radius: 20rpx;
  margin: 30rpx 0;
  position: relative;
}

.npc-name {
  display: block;
  font-weight: bold;
  color: #8B2323;
  margin-bottom: 10rpx;
}

.npc-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.guide-steps {
  width: 100%;
  display: flex;
  justify-content: space-around;
  margin: 20rpx 0 40rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.step-icon {
  font-size: 50rpx;
}

.step text {
  font-size: 24rpx;
  color: #666;
}

.start-btn {
  width: 80%;
  background: #8B2323;
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
  padding: 20rpx 0;
}

/* 倒计时样式 */
.countdown-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 900;
}

.countdown-text {
  font-size: 150rpx;
  font-weight: bold;
  color: #8B2323;
  text-shadow: 0 0 20rpx rgba(255,255,255,0.8);
  animation: countdownPop 1s infinite;
}

@keyframes countdownPop {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(1); opacity: 0; }
}

.event-toast {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(139, 35, 35, 0.8);
  color: #fff;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  z-index: 500;
  animation: fadeInOut 2s ease-in-out;
}

@keyframes fadeInOut {
  0% { opacity: 0; transform: translate(-50%, -30%); }
  20% { opacity: 1; transform: translate(-50%, -50%); }
  80% { opacity: 1; transform: translate(-50%, -50%); }
  100% { opacity: 0; transform: translate(-50%, -70%); }
}
