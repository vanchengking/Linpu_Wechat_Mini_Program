.game-container {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  position: relative;
  background-color: #004d7a; /* 深蓝色海域 */
}

/* 海浪动画背景 */
.sea-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  overflow: hidden;
}

.wave {
  position: absolute;
  width: 200%;
  height: 100%;
  background-repeat: repeat-x;
  background-position: 0 bottom;
  transform-origin: center bottom;
}

.wave1 {
  background: radial-gradient(circle at 50% 100%, rgba(255,255,255,0.1) 0%, transparent 80%);
  animation: waveMove 10s linear infinite;
  opacity: 0.3;
}

.wave2 {
  background: radial-gradient(circle at 30% 100%, rgba(255,255,255,0.05) 0%, transparent 70%);
  animation: waveMove 15s linear infinite reverse;
  opacity: 0.2;
}

@keyframes waveMove {
  from { transform: translateX(0) skewX(0); }
  to { transform: translateX(-50%) skewX(5deg); }
}

.game-canvas {
  width: 100%;
  height: 100%;
  display: block;
  position: relative;
  z-index: 2;
}

.score-panel-wrap {
  position: absolute;
  top: 30rpx;
  right: 20rpx;
  z-index: 100;
}

/* 追兵进度条 */
.enemy-distance {
  position: absolute;
  top: 0;
  left: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #ff4d4d, #8B2323);
  box-shadow: 0 2rpx 10rpx rgba(139, 35, 35, 0.5);
  z-index: 150;
  transition: width 0.5s linear;
}

.enemy-label {
  position: absolute;
  right: 0;
  top: 10rpx;
  font-size: 18rpx;
  color: #ff4d4d;
  font-weight: bold;
  white-space: nowrap;
}

/* 引导层样式 */
.tutorial-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
  backdrop-filter: blur(5px);
}

.tutorial-content {
  width: 85%;
  background: #fff;
  border-radius: 40rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.3);
  position: relative;
}

.npc-portrait {
  width: 200rpx;
  height: 200rpx;
  margin-top: -120rpx;
  border-radius: 50%;
  border: 6rpx solid #8B2323;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.2);
}

.speech-bubble {
  background: #fdf6ec;
  border: 2rpx solid #e6a23c;
  padding: 20rpx;
  border-radius: 20rpx;
  margin: 30rpx 0;
  position: relative;
}

.npc-name {
  display: block;
  font-weight: bold;
  color: #8B2323;
  margin-bottom: 10rpx;
}

.npc-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.guide-steps {
  width: 100%;
  display: flex;
  justify-content: space-around;
  margin: 20rpx 0 40rpx;
}

.step {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.step-icon {
  font-size: 50rpx;
}

.step text {
  font-size: 24rpx;
  color: #666;
}

.start-btn {
  width: 80%;
  background: #8B2323;
  color: #fff;
  border-radius: 50rpx;
  font-weight: bold;
  padding: 20rpx 0;
}

/* 倒计时样式 */
.countdown-overlay {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 900;
}

.countdown-text {
  font-size: 150rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 0 20rpx rgba(139, 35, 35, 0.8);
  animation: countdownPop 1s infinite;
}

@keyframes countdownPop {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.2); opacity: 1; }
  100% { transform: scale(1); opacity: 0; }
}

.event-toast {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(139, 35, 35, 0.8);
  color: #fff;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
  z-index: 500;
  animation: fadeInOut 2s ease-in-out;
}

@keyframes fadeInOut {
  0% { opacity: 0; transform: translate(-50%, -30%); }
  20% { opacity: 1; transform: translate(-50%, -50%); }
  80% { opacity: 1; transform: translate(-50%, -50%); }
  100% { opacity: 0; transform: translate(-50%, -70%); }
}