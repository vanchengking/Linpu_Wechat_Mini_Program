/* 容器基础样式 */
.experience-container {
  padding: 40rpx 30rpx;
  background: url('https://asave.rutno.com/fileview?id=S8JAJK5wKDye') no-repeat center center;
  background-size: cover;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: center;
  padding-top: 80rpx;
}

.section-header {
  margin-bottom: 50rpx;
  text-align: center;
  width: 100%;
}

.title {
  font-size: 48rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  letter-spacing: 2rpx;
  font-weight: 300;
}

/* 网格布局 */
.grid-layout {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  width: 100%;
}

/* 卡片样式与点击效果 */
.experience-card {
  background: rgba(255, 255, 255, 0.85); /* 半透明白色背景 */
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.06);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(12rpx); /* 背景模糊效果 */
  aspect-ratio: 1/1; /* 正方形卡片 */
}

/* 点击/按压反馈核心代码 */
.card-hover {
  transform: scale(0.96); /* 缩小效果 */
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.02);
  background-color: #fafafa;
}

.card-icon-box {
  width: 120rpx;
  height: 120rpx;
  background-color: rgba(139, 35, 35, 0.08); /* 淡红背景 */
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  overflow: hidden; /* 确保图片不会超出圆形容器 */
}

.card-icon {
  width: 100%;
  height: 100%;
  border-radius: 50%; /* 使图片也成为圆形 */
  object-fit: cover; /* 保持图片比例，短边等于容器直径，长边被裁剪 */
  object-position: center; /* 图片居中显示 */
}

.card-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
  text-align: center;
}

.card-tag {
  font-size: 24rpx;
  color: #8B2323; /* 主题红 */
  border: 1rpx solid rgba(139, 35, 35, 0.3);
  padding: 4rpx 16rpx;
  border-radius: 12rpx;
}

/* 弹窗样式 */
.modal-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 999;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s;
}

.modal-wrapper.active {
  visibility: visible;
  opacity: 1;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
}

.modal-card {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 85%;
  max-height: 80vh;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  backdrop-filter: blur(10rpx);
}

.modal-wrapper.active .modal-card {
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
}

.close-icon {
  font-size: 40rpx;
  color: #999;
  padding: 10rpx;
}

.modal-scroll {
  flex: 1;
  overflow-y: auto;
}

/* 轮播容器样式 */
.swiper-container {
  width: 100%;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.swiper {
  width: 100%;
  height: 100%;
  border-radius: 0;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 轮播指示点样式 */
.swiper .wx-swiper-dots {
  bottom: 20rpx;
}

.swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  margin: 0 6rpx;
}

.swiper .wx-swiper-dot-active {
  background: #8B2323;
  width: 24rpx;
  border-radius: 6rpx;
}

.modal-hero-img {
  width: 100%;
  height: 360rpx;
  background-color: #eee;
}

.content-block {
  padding: 30rpx 30rpx 10rpx 30rpx;
}

.block-label {
  display: inline-block;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  background-color: #8B2323;
  padding: 6rpx 16rpx;
  border-radius: 0 16rpx 0 16rpx;
  margin-bottom: 16rpx;
}

.block-text {
  display: block;
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

.modal-footer {
  padding: 24rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  background-color: #8B2323;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
}