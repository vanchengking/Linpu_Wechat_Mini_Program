/* 页面基础样式 */
page {
  background-color: #000;
}

/* 容器基础样式 */
.experience-container {
  position: relative;
  min-height: 100vh;
  width: 100%;
  overflow: hidden;
}

/* 背景图 */
.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 背景遮罩层 - 使用米黄色调渐变 */
.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    135deg,
    rgba(252, 247, 227, 0.92) 0%,
    rgba(248, 244, 230, 0.88) 50%,
    rgba(240, 235, 220, 0.9) 100%
  );
  z-index: 2;
}

/* 内容包装器 */
.content-wrapper {
  position: relative;
  z-index: 10;
  padding: 80rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.section-header {
  margin-bottom: 60rpx;
  text-align: center;
  width: 100%;
}

.title {
  font-size: 52rpx;
  font-weight: 700;
  color: #4a4035;
  margin-bottom: 16rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.08);
  letter-spacing: 4rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6c6553;
  letter-spacing: 3rpx;
  font-weight: 400;
}

/* 网格布局 */
.grid-layout {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
  width: 100%;
}

/* 卡片样式与点击效果 */
.experience-card {
  background: rgba(255, 255, 255, 0.75);
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 8rpx 24rpx rgba(109, 83, 68, 0.12),
    0 2rpx 8rpx rgba(109, 83, 68, 0.06);
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(16rpx);
  aspect-ratio: 1/1;
  border: 1rpx solid rgba(255, 255, 255, 0.5);
}

/* 点击/按压反馈 */
.card-hover {
  transform: scale(0.96);
  box-shadow: 
    0 4rpx 12rpx rgba(109, 83, 68, 0.08),
    0 1rpx 4rpx rgba(109, 83, 68, 0.04);
  background-color: rgba(255, 255, 255, 0.9);
}

.card-icon-box {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, rgba(139, 35, 35, 0.1) 0%, rgba(139, 35, 35, 0.05) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(139, 35, 35, 0.1);
}

.card-icon {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  object-position: center;
  transform: scale(1.5);
}

.card-label {
  font-size: 34rpx;
  font-weight: 600;
  color: #4a4035;
  margin-bottom: 12rpx;
  text-align: center;
  letter-spacing: 2rpx;
}

.card-tag {
  font-size: 22rpx;
  color: #8B2323;
  background: rgba(139, 35, 35, 0.08);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

/* 弹窗样式 */
.modal-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 999;
  visibility: hidden;
  opacity: 0;
  transition: opacity 0.3s;
}

.modal-wrapper.active {
  visibility: visible;
  opacity: 1;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.5);
  backdrop-filter: blur(8rpx);
}

.modal-card {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  width: 85%;
  max-height: 80vh;
  background: rgba(252, 247, 227, 0.95);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.2);
}

.modal-wrapper.active .modal-card {
  transform: translate(-50%, -50%) scale(1);
}

.modal-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid rgba(109, 83, 68, 0.15);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #4a4035;
  letter-spacing: 2rpx;
}

.close-icon {
  font-size: 40rpx;
  color: #6c6553;
  padding: 10rpx;
  transition: color 0.2s;
}

.close-icon:active {
  color: #8B2323;
}

.modal-scroll {
  flex: 1;
  overflow-y: auto;
}

/* 轮播容器样式 */
.swiper-container {
  width: 100%;
  height: 400rpx;
  margin-bottom: 20rpx;
}

.swiper {
  width: 100%;
  height: 100%;
  border-radius: 0;
}

.swiper-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 轮播指示点样式 */
.swiper .wx-swiper-dots {
  bottom: 20rpx;
}

.swiper .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 50%;
  margin: 0 6rpx;
}

.swiper .wx-swiper-dot-active {
  background: #8B2323;
  width: 24rpx;
  border-radius: 6rpx;
}

.modal-hero-img {
  width: 100%;
  height: 360rpx;
  background-color: #eee;
}

.content-block {
  padding: 30rpx 30rpx 10rpx 30rpx;
}

.block-label {
  display: inline-block;
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  background: linear-gradient(135deg, #8B2323 0%, #6b1a1a 100%);
  padding: 8rpx 20rpx;
  border-radius: 0 16rpx 0 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 8rpx rgba(139, 35, 35, 0.2);
}

.block-text {
  display: block;
  font-size: 28rpx;
  color: #5a5045;
  line-height: 1.8;
  text-align: justify;
}

.modal-footer {
  padding: 24rpx 30rpx;
  border-top: 1rpx solid rgba(109, 83, 68, 0.1);
}

.action-btn {
  background: linear-gradient(135deg, #8B2323 0%, #6b1a1a 100%);
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(139, 35, 35, 0.3);
  transition: all 0.2s;
}

.action-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 6rpx rgba(139, 35, 35, 0.2);
}
