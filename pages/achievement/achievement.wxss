/* ========== 成就页面样式 ========== */

page {
  background: linear-gradient(180deg, #fcf7e3 0%, #f5ead6 100%);
  min-height: 100vh;
}

.achievement-page {
  padding: 20rpx;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 用户信息卡片 ========== */
.user-card {
  background: linear-gradient(135deg, #d4a574 0%, #c49a6c 50%, #b8895e 100%);
  border-radius: 24rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(180, 140, 90, 0.35);
  margin-bottom: 28rpx;
  position: relative;
  overflow: hidden;
}

.user-card::after {
  content: '';
  position: absolute;
  top: -40rpx;
  right: -40rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
}

.user-info-row {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
  position: relative;
  z-index: 1;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.7);
  background: #fff;
  flex-shrink: 0;
}

.user-detail {
  margin-left: 24rpx;
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #fff;
  display: block;
  margin-bottom: 6rpx;
}

.user-title {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
  display: block;
  margin-bottom: 12rpx;
}

.exp-bar-bg {
  width: 100%;
  height: 24rpx;
  background: rgba(0,0,0,0.25);
  border-radius: 12rpx;
  position: relative;
  overflow: hidden;
}

.exp-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffe066, #ffc53d);
  border-radius: 12rpx;
  transition: width 0.5s ease;
}

.exp-text {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  font-size: 18rpx;
  color: #fff;
  font-weight: 500;
  text-shadow: 0 1rpx 2rpx rgba(0,0,0,0.3);
}

/* ========== 数据统计网格 ========== */
.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  position: relative;
  z-index: 1;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 16rpx;
}

.stat-num {
  font-size: 42rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.2;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255,255,255,0.25);
}

/* ========== 区块通用样式 ========== */
.section {
  background: #fffaf2;
  border-radius: 20rpx;
  padding: 28rpx 26rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(160,130,90,0.1);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
  padding-bottom: 18rpx;
  border-bottom: 1rpx solid rgba(180,150,110,0.15);
}

.section-icon {
  width: 38rpx;
  height: 38rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3c2a1e;
  flex: 1;
}

.badge-count,
.achievement-count {
  font-size: 24rpx;
  color: #b8895e;
  font-weight: 500;
}

/* ========== 徽章墙 ========== */
.badge-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 16rpx 12rpx;
}

.badge-item {
  width: calc(33.33% - 8rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 8rpx 14rpx;
  background: #fdf6e8;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.25s ease;
  border: 2rpx solid transparent;
}

.badge-item.unlocked {
  background: linear-gradient(135deg, #fffbf0, #fff8dc);
  border-color: #e8d5a3;
  box-shadow: 0 3rpx 12rpx rgba(216,180,100,0.2);
}

.badge-item.locked {
  opacity: 0.75;
}

.badge-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 10rpx;
}

.badge-name {
  font-size: 22rpx;
  color: #4a3a2a;
  font-weight: 500;
  text-align: center;
}

.badge-check,
.badge-lock {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16rpx;
}

.badge-check {
  background: #52c41a;
  color: #fff;
}

.badge-lock {
  background: #d9d9d9;
  color: #999;
}

/* ========== 成就列表 ========== */
.achievement-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.achievement-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fef9ee;
  border-radius: 14rpx;
  padding: 22rpx 20rpx;
  border: 2rpx solid #efe0cc;
  transition: all 0.2s ease;
  position: relative;
  overflow: hidden;
}

.achievement-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: #d4a574;
  opacity: 0.6;
}

.achievement-item.completed {
  background: #f0f7ea;
  border-color: #c8e6a0;
}

.achievement-item.completed::before {
  background: #52c41a;
}

.ach-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

.ach-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  background: #e8d5a3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #8b6914;
  font-weight: bold;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.ach-icon-wrap.done {
  background: #52c41a;
  color: #fff;
}

.ach-info {
  flex: 1;
  min-width: 0;
}

.ach-name {
  font-size: 27rpx;
  font-weight: 600;
  color: #3c2a1e;
  display: block;
  margin-bottom: 4rpx;
}

.ach-desc {
  font-size: 22rpx;
  color: #8a7a68;
  display: block;
  line-height: 1.4;
}

.progress-wrap {
  display: flex;
  align-items: center;
  margin-top: 10rpx;
  gap: 10rpx;
}

.progress-bar {
  flex: 1;
  height: 14rpx;
  background: #e8ddd0;
  border-radius: 7rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #e8a849, #d4883a);
  border-radius: 7rpx;
  transition: width 0.35s ease;
}

.progress-text {
  font-size: 20rpx;
  color: #b08a50;
  flex-shrink: 0;
}

.ach-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.ach-reward {
  font-size: 22rpx;
  color: #e8a030;
  font-weight: bold;
  background: #fff8e1;
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
}

.ach-arrow {
  font-size: 28rpx;
  color: #b8895e;
  margin-top: 6rpx;
}

.ach-done-text {
  font-size: 20rpx;
  color: #52c41a;
  margin-top: 6rpx;
  font-weight: 500;
}

/* ========== 排行榜入口 ========== */
.rank-section {
  cursor: pointer;
}

.rank-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 18rpx;
}

.rank-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #3c2a1e;
}

.rank-arrow {
  font-size: 23rpx;
  color: #b8895e;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 14rpx 16rpx;
  background: #fef9ee;
  border-radius: 10rpx;
}

.rank-item.isMe {
  background: #fff8e1;
  border: 1rpx solid #e8d5a3;
}

.rank-pos {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  width: 50rpx;
  text-align: center;
}

.rank-pos.gold { color: #ffd700; }
.rank-pos.silver { color: #c0c0c0; }
.rank-pos.bronze { color: #cd7f32; }

.rank-name {
  font-size: 25rpx;
  color: #3c2a1e;
  flex: 1;
  margin-left: 12rpx;
}

.rank-level-tag {
  font-size: 19rpx;
  color: #fff;
  padding: 3rpx 14rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
}

.lv1, .lv2, .lv3 { background: #95a5a6; }
.lv4, .lv5 { background: #3498db; }
.lv6, .lv7 { background: #9b59b6; }
.lv8, .lv9 { background: #e67e22; }

.rank-exp {
  font-size: 22rpx;
  color: #b8895e;
  font-weight: 500;
}

/* ========== 徽章详情弹窗 ========== */
.badge-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-modal {
  width: 85%;
  background: #fffaf2;
  border-radius: 24rpx;
  padding: 44rpx 32rpx;
  text-align: center;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.25);
}

.badge-modal-header {
  margin-bottom: 24rpx;
}

.badge-modal-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
}

.badge-modal-name {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #3c2a1e;
  margin-bottom: 8rpx;
}

.badge-modal-status {
  display: inline-block;
  font-size: 22rpx;
  color: #52c41a;
  background: #f0f7ea;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
}

.badge-modal-status.locked-status {
  color: #999;
  background: #f0f0f0;
}

.badge-modal-desc {
  display: block;
  font-size: 26rpx;
  color: #5a4a3a;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.badge-modal-tip {
  display: block;
  font-size: 23rpx;
  color: #b8895e;
  line-height: 1.5;
  margin-bottom: 12rpx;
  text-align: left;
}

.badge-modal-time {
  display: block;
  font-size: 23rpx;
  color: #888;
  margin-bottom: 24rpx;
}

.badge-modal-close {
  display: inline-block;
  background: linear-gradient(135deg, #d4a574, #b8895e);
  color: #fff;
  font-size: 28rpx;
  padding: 16rpx 72rpx;
  border-radius: 40rpx;
  font-weight: 500;
}
