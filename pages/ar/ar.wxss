.container {
  width: 100vw;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background-color: #000;
}

.full-screen {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
}

.design-bg {
  filter: brightness(0.6);
}

.ar-canvas {
  width: 100%;
  height: 100%;
}

.view-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 20;
  display: flex;
  flex-direction: column;
}

/* 顶部状态栏 */
.top-bar {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 160rpx;
  padding: 80rpx 40rpx 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 50;
  box-sizing: border-box;
}

.back-btn, .mode-toggle {
  background: rgba(0, 0, 0, 0.5);
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  color: #fff;
  font-size: 24rpx;
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.level-info {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.8);
}

/* 关卡选择界面 */
.level-selection {
  background: rgba(0, 0, 0, 0.5);
  backdrop-filter: blur(15px);
}

.header {
  padding: 120rpx 40rpx 60rpx;
  text-align: center;
}

.title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 6rpx;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3);
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: #ccc;
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}

.level-list {
  flex: 1;
  padding: 0 40rpx 40rpx;
  box-sizing: border-box;
}

.level-card {
  background: rgba(255, 255, 255, 0.1);
  border: 1px solid rgba(255, 255, 255, 0.15);
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  display: flex;
  align-items: center;
  transition: transform 0.2s;
}

.level-card:active {
  transform: scale(0.98);
}

.level-card.locked {
  opacity: 0.4;
  filter: grayscale(1);
}

.level-num {
  width: 90rpx;
  height: 90rpx;
  background: linear-gradient(135deg, #f1c40f, #f39c12);
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-right: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(241, 196, 15, 0.3);
}

.level-info {
  flex: 1;
}

.level-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.level-desc {
  display: block;
  font-size: 24rpx;
  color: #bbb;
  margin-top: 10rpx;
}

.level-status {
  font-size: 24rpx;
  color: #f1c40f;
  font-weight: bold;
}

/* 游戏对话界面 */
.game-play {
  justify-content: flex-end;
}

.character-area {
  flex: 1;
  position: relative;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  pointer-events: none;
}

.character-image {
  width: 80%;
  height: 70%;
  transition: all 0.5s ease-out;
}

.character-image.center { transform: translateY(0); }
.character-image.left { transform: translateX(-20%); }
.character-image.right { transform: translateX(20%); }

.dialogue-container {
  padding: 40rpx;
  padding-bottom: 80rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
}

.options-box {
  margin-bottom: 40rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  background: rgba(255, 255, 255, 0.9);
  color: #333;
  padding: 25rpx 40rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.2);
  animation: fadeIn 0.3s ease-out;
}

.option-item:active {
  background: #f1c40f;
  color: #fff;
}

.dialogue-box {
  background: rgba(0, 0, 0, 0.7);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 24rpx;
  padding: 40rpx;
  min-height: 200rpx;
  position: relative;
  backdrop-filter: blur(10px);
}

.name-tag {
  position: absolute;
  top: -30rpx;
  left: 40rpx;
  background: #f1c40f;
  color: #333;
  padding: 8rpx 30rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.content {
  font-size: 32rpx;
  color: #fff;
  line-height: 1.6;
}

.next-indicator {
  position: absolute;
  bottom: 20rpx;
  right: 30rpx;
  color: #f1c40f;
  font-size: 24rpx;
  animation: bounce 1.5s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* Modal */
.modal {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.85);
  z-index: 100;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  background: #fff;
  width: 80%;
  padding: 80rpx 40rpx;
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.modal-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-info {
  font-size: 30rpx;
  color: #666;
  margin-bottom: 60rpx;
}

.modal-btn {
  background: linear-gradient(135deg, #2ecc71, #27ae60);
  color: #fff;
  font-size: 32rpx;
  width: 360rpx !important;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 10rpx 25rpx rgba(46, 204, 113, 0.3);
}
