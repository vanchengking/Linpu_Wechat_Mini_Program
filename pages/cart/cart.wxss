page {
  background-color: #f5f5f5;
  height: 100%;
}

.container {
  padding-bottom: 120rpx;
  min-height: 100vh;
}

/* 列表容器 */
.cart-list {
  padding: 20rpx;
}

/* 列表项 */
.cart-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.checkbox-box {
  padding: 10rpx;
}

.product-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin: 0 20rpx;
}

.product-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  height: 160rpx;
}

.product-name {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.price-stepper {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price {
  font-size: 32rpx;
  color: #e74c3c;
  font-weight: bold;
}

/* 步进器 */
.stepper {
  display: flex;
  align-items: center;
  border: 1rpx solid #eee;
  border-radius: 8rpx;
  overflow: hidden;
}

.stepper view {
  width: 50rpx;
  height: 50rpx;
  text-align: center;
  line-height: 50rpx;
  background-color: #f9f9f9;
  font-size: 32rpx;
  color: #666;
}

.stepper view:active {
  background-color: #eee;
}

.stepper .disabled {
  color: #ccc;
  background-color: #f9f9f9;
}

.stepper input {
  width: 70rpx;
  height: 50rpx;
  text-align: center;
  font-size: 24rpx;
  border-left: 1rpx solid #eee;
  border-right: 1rpx solid #eee;
  background-color: #fff;
}

/* 删除按钮 */
.delete-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #999;
  padding: 10rpx;
}

/* 空状态 */
.empty-cart {
  padding-top: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.3;
  margin-bottom: 40rpx;
}

.empty-cart text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 60rpx;
}

.go-shopping {
  width: 300rpx !important;
  background-color: #8B2323;
  color: #fff;
  border-radius: 40rpx;
  font-size: 28rpx;
}

/* 优惠券与价格详情 */
.coupon-section {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 30rpx 40rpx;
  margin-top: 20rpx;
}

.coupon-section .label {
  font-size: 28rpx;
  color: #333;
  width: 120rpx;
}

.coupon-section .value {
  flex: 1;
  font-size: 26rpx;
  color: #999;
  text-align: right;
  padding-right: 20rpx;
}

.coupon-section .value.selected {
  color: #e74c3c;
  font-weight: bold;
}

.price-detail {
  background-color: #fff;
  padding: 20rpx 40rpx;
  margin-top: 2rpx;
}

.price-item {
  display: flex;
  justify-content: space-between;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.price-item.red {
  color: #e74c3c;
}

/* 底部结算栏 */
.footer-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 100rpx;
  background-color: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-sizing: border-box;
  box-shadow: 0 -4rpx 10rpx rgba(0,0,0,0.05);
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 100;
}

.select-all {
  display: flex;
  align-items: center;
}

.select-all text {
  font-size: 26rpx;
  color: #666;
  margin-left: 10rpx;
}

.total-info {
  flex: 1;
  text-align: right;
  padding-right: 30rpx;
}

.total-info .label {
  font-size: 26rpx;
  color: #666;
}

.total-info .total-price {
  font-size: 36rpx;
  color: #e74c3c;
  font-weight: bold;
  margin-left: 10rpx;
}

.checkout-btn {
  width: 240rpx !important;
  height: 70rpx;
  line-height: 70rpx;
  background-color: #8B2323;
  color: #fff;
  font-size: 28rpx;
  border-radius: 35rpx;
  padding: 0;
  margin: 0;
}