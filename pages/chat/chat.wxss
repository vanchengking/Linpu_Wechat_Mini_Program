.container {
  background: url('https://asave.rutno.com/fileview?id=S8JAJK5wKDye') no-repeat center center;
  background-size: cover;
}

.container {
  width: 100%;
  height: 100%;
  position: relative;
  overflow: hidden;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: 80rpx;
  left: 30rpx;
  z-index: 20;
  background: rgba(0,0,0,0.4);
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  border: 2rpx solid rgba(255,255,255,0.8);
  transition: all 0.3s ease;
}
.back-btn:active {
  background: rgba(0,0,0,0.6);
  transform: scale(0.95);
}
.back-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 背景图 */
.bg-img {
  display: none;
}

/* 固定人物 */
.character-area {
  position: fixed;
  bottom: 150rpx;
  left: 10rpx;
  z-index: 10;
  transform-origin: center bottom; 
  opacity: 0;
  animation: fadeInUp 1s ease-out forwards;
}

.character {
  width: 240rpx;
  opacity: 1;
  display: block;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 消息容器 */
.message-container {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 150rpx;
  z-index: 1;
  display: flex;
  flex-direction: column;
  padding: 0 20rpx;
  justify-content: flex-end;
}

/* 初始气泡 */
.initial-bubble {
  position: fixed;
  bottom: 160rpx;
  right: 20rpx;
  display: flex;
  justify-content: flex-end;
  z-index: 5;
}

.bubble {
  max-width: 460rpx;
  padding: 22rpx 28rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.85);
  color: #333;
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: justify;
  word-wrap: break-word;
  word-break: break-all;
  min-height: 80rpx;
}

/* 用户消息气泡 */
.message-item {
  margin: 30rpx 40rpx;
  display: flex;
  justify-content: flex-end;
}

.user-bubble {
  max-width: 330rpx;
  padding: 22rpx 28rpx;
  border-radius: 18rpx;
  background: rgba(109,83,68,0.9);
  color: white;
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: justify;
  word-wrap: break-word;
  word-break: break-all;
  min-height: 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

/* AI消息气泡 */
.ai-bubble {
  max-width: 330rpx;
  padding: 22rpx 28rpx;
  border-radius: 18rpx;
  background: rgba(244, 244, 244, 0.78);
  color: #333333ff; 
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: justify;
  word-wrap: break-word;
  word-break: break-all;
  min-height: 60rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); 
}

/* 底部输入栏 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #a8a59ccb;
  padding: 20rpx 20rpx 30rpx 20rpx; /* 上下内边距 */
  display: flex;
  align-items: center;
  gap: 20rpx;
  z-index: 20;
  border-top: 1rpx solid rgba(255,255,255,0.1);
  min-height: 30rpx; /* 最小高度 */
}

.input-wrapper {
  flex: 1;
  background: rgba(255,255,255,0.9);
  border-radius: 50rpx;
  padding: 0 30rpx;
  margin-bottom: 10rpx; /* 增加输入框底部边距 */
}

.input-box {
  height: 80rpx; /* 增加输入框高度 */
  font-size: 30rpx;
  color: #333;
}

.voice-btn {
  width: 80rpx; /* 进一步增加按钮尺寸 */
  height: 80rpx;
  background: #5a5445;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx; /* 增加语音按钮底部边距 */
}

.voice-icon {
  width: 50rpx; /* 进一步增加图标尺寸 */
  height: 50rpx;
}

.send-btn {
  width: 160rpx;
  height: 80rpx;
  background: #5a5445;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 34rpx; /* 进一步增大字体 */
  font-weight: bold;
  margin-bottom: 10rpx; /* 增加发送按钮底部边距 */
}

.send-btn:active {
  background: #5a5445;
  transform: scale(0.95);
}