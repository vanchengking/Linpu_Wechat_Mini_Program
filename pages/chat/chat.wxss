/* 注意：小程序 WXSS 不支持外部网络 URL 作为 background-image
   背景图已通过 <image> 标签在 wxml 中实现 */
page {
  height: 100%;
  background-color: #f5f0e8;
}

.container {
  width: 100%;
  height: 100vh;
  position: relative;
  overflow: hidden;
  background-color: #f5f0e8;
}

/* 返回按钮 */
.back-btn {
  position: absolute;
  top: 80rpx;
  left: 30rpx;
  z-index: 20;
  background: rgba(0,0,0,0.4);
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  border: 2rpx solid rgba(255,255,255,0.8);
}
.back-btn:active {
  background: rgba(0,0,0,0.6);
  transform: scale(0.95);
}
.back-text {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

/* 背景图 — 铺满整个页面 */
.bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  background-color: transparent !important; /* 覆盖全局 image 背景色 */
}

/* 固定人物 — 底部紧贴输入栏上方 */
.character-area {
  position: fixed;
  bottom: 140rpx;
  left: 10rpx;
  z-index: 10;
}

.character {
  width: 240rpx;
  display: block;
  background-color: transparent !important; /* 覆盖全局 image 背景色 */
}

/* 消息容器 — scroll-view 必须有固定高度 */
.message-container {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 140rpx;
  height: calc(100vh - 120rpx);
  z-index: 1;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 初始气泡 */
.initial-bubble {
  position: fixed;
  bottom: 180rpx;
  right: 20rpx;
  display: flex;
  justify-content: flex-end;
  z-index: 5;
}

.bubble {
  max-width: 460rpx;
  padding: 22rpx 28rpx;
  border-radius: 18rpx;
  background: rgba(255,255,255,0.85);
  color: #333;
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: justify;
  word-wrap: break-word;
  word-break: break-all;
  min-height: 80rpx;
}

/* 用户消息气泡 */
.message-item {
  margin: 30rpx 40rpx;
  display: flex;
  justify-content: flex-end;
}

.user-bubble {
  max-width: 330rpx;
  padding: 22rpx 28rpx;
  border-radius: 18rpx;
  background: rgba(109,83,68,0.9);
  color: white;
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: justify;
  word-wrap: break-word;
  word-break: break-all;
  min-height: 60rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}

/* AI消息气泡 */
.ai-bubble {
  max-width: 330rpx;
  padding: 22rpx 28rpx;
  border-radius: 18rpx;
  background: rgba(244, 244, 244, 0.78);
  color: #333333ff; 
  font-size: 30rpx;
  line-height: 36rpx;
  text-align: justify;
  word-wrap: break-word;
  word-break: break-all;
  min-height: 60rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); 
}

/* 底部输入栏 */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #a8a59ccb;
  padding: 20rpx 20rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 0rpx);
  display: flex;
  align-items: center;
  gap: 16rpx;
  z-index: 20;
}

.input-wrapper {
  flex: 1;
  background: rgba(255,255,255,0.9);
  border-radius: 50rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
}

.input-box {
  height: 76rpx;
  font-size: 28rpx;
  color: #333;
}

.voice-btn {
  flex-shrink: 0;
  width: 76rpx;
  height: 76rpx;
  background: #5a5445;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.voice-btn:active {
  background: #3d3830;
  transform: scale(0.95);
}

.voice-icon {
  width: 44rpx;
  height: 44rpx;
  background-color: transparent !important;
}

.send-btn {
  flex-shrink: 0;
  width: 140rpx;
  height: 76rpx;
  background: #5a5445;
  border-radius: 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 30rpx;
  font-weight: bold;
}

.send-btn:active {
  background: #3d3830;
  transform: scale(0.95);
}