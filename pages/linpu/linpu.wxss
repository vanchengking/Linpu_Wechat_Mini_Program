/* ========== 林浦印象页面样式 ========== */

page {
  background: linear-gradient(180deg, #fcf7e3 0%, #f5ead6 100%);
  min-height: 100vh;
}

.linpu-page {
  padding: 0 0 20rpx;
}

/* ========== 顶部大图 ========== */
.hero-section {
  position: relative;
  width: 100%;
  height: 480rpx;
  overflow: hidden;
}

.hero-img {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(60,42,30,0.1) 0%, rgba(60,42,30,0.6) 100%);
}

.hero-content {
  position: absolute;
  bottom: 48rpx;
  left: 0;
  right: 0;
  text-align: center;
  z-index: 2;
}

.hero-title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 12rpx;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
  margin-bottom: 12rpx;
}

.hero-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 6rpx;
}

/* ========== 通用区块 ========== */
.section-card, .intro-card {
  margin: 24rpx 24rpx 0;
  background: #fffaf2;
  border-radius: 20rpx;
  padding: 28rpx 26rpx;
  box-shadow: 0 4rpx 16rpx rgba(160,130,90,0.1);
}

.section-divider {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: rgba(180,150,110,0.25);
}

.divider-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #3c2a1e;
  padding: 0 20rpx;
}

/* ========== 简介 ========== */
.intro-text {
  font-size: 26rpx;
  color: #5a4a3a;
  line-height: 1.8;
  letter-spacing: 1rpx;
}

/* ========== 核心看点 ========== */
.highlight-grid {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.highlight-item {
  display: flex;
  align-items: flex-start;
  padding: 18rpx;
  background: #fef9ee;
  border-radius: 14rpx;
  border: 1rpx solid #efe0cc;
}

.highlight-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #d4a574, #b8895e);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.highlight-icon {
  font-size: 34rpx;
}

.highlight-info {
  flex: 1;
}

.highlight-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #3c2a1e;
  margin-bottom: 6rpx;
}

.highlight-desc {
  display: block;
  font-size: 23rpx;
  color: #8a7a68;
  line-height: 1.5;
}

/* ========== 历史脉络 ========== */
.timeline {
  position: relative;
  padding-left: 32rpx;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 11rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: 2rpx;
  background: linear-gradient(180deg, #d4a574, #e8d5a3);
}

.timeline-item {
  position: relative;
  padding-bottom: 24rpx;
  padding-left: 24rpx;
}

.timeline-item:last-child {
  padding-bottom: 0;
}

.timeline-dot {
  position: absolute;
  left: -27rpx;
  top: 8rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #d4a574;
  border: 3rpx solid #fffaf2;
  box-shadow: 0 0 0 3rpx rgba(212,165,116,0.3);
}

.timeline-content {
  display: flex;
  flex-direction: column;
}

.timeline-era {
  font-size: 24rpx;
  font-weight: bold;
  color: #b8895e;
  margin-bottom: 4rpx;
}

.timeline-event {
  font-size: 25rpx;
  color: #5a4a3a;
  line-height: 1.5;
}

/* ========== 数据概览 ========== */
.stats-card {
  margin: 24rpx 24rpx 0;
  background: linear-gradient(135deg, #d4a574 0%, #b8895e 100%);
  border-radius: 20rpx;
  padding: 28rpx 20rpx;
  box-shadow: 0 8rpx 30rpx rgba(180,140,90,0.35);
}

.stats-row {
  display: flex;
  justify-content: space-around;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 4rpx;
}

/* ========== 底部探索入口 ========== */
.explore-section {
  margin: 32rpx 24rpx 0;
  text-align: center;
}

.explore-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #3c2a1e;
  margin-bottom: 20rpx;
}

.explore-btns {
  display: flex;
  justify-content: space-around;
}

.explore-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 22rpx 16rpx;
  background: #fffaf2;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(160,130,90,0.1);
  border: 1rpx solid #efe0cc;
  min-width: 160rpx;
}

.explore-btn-icon {
  font-size: 44rpx;
  margin-bottom: 10rpx;
}

.explore-btn-text {
  font-size: 24rpx;
  color: #3c2a1e;
  font-weight: 500;
}
