/* pages/decode/decode.wxss */
page {
  background-color: #000;
}

.container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 背景遮罩层 */
.bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.2) 50%, rgba(0,0,0,0.4) 100%);
  z-index: 2;
}

.top-title {
  position: absolute;
  top: 12%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 56rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.5);
  letter-spacing: 8rpx;
  z-index: 10;
}

.vertical-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  justify-content: center;
  flex-direction: row;
  z-index: 10;
  width: 100%;
}

.vertical-column {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.left-column {
  margin-right: 60rpx;
  margin-top: -80rpx;
}

.right-column {
  margin-left: 60rpx;
  margin-top: 20rpx;
}

.calligraphy-text {
  font-family: 'Microsoft YaHei', '微软雅黑', sans-serif;
  font-size: 72rpx;
  font-weight: bold;
  color: #ffffff;
  text-shadow: 2rpx 2rpx 0 rgba(0,0,0,0.3), 0 4rpx 12rpx rgba(0,0,0,0.4);
  line-height: 1.4;
  margin: 16rpx 0;
  opacity: 0.98;
  display: block;
  text-align: center;
}

.offset-1 { transform: translateY(8rpx); }
.offset-2 { transform: translateY(16rpx); }
.offset-3 { transform: translateY(24rpx); }
.offset-4 { transform: translateY(32rpx); }

.swipe-tip {
  position: absolute;
  bottom: 120rpx;
  width: 100%;
  text-align: center;
  color: #ffffff;
  text-shadow: 0 0 8rpx rgba(0,0,0,0.6);
  z-index: 10;
}

.arrow {
  font-size: 42rpx;
  margin-bottom: 10rpx;
}

.tip-text {
  font-size: 28rpx;
  text-align: center;
  line-height: 1.5;
  letter-spacing: 2rpx;
}
