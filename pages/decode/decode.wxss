/* pages/decode/decode.wxss */
.container {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

.top-title {
  position: absolute;
  top: 15%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 28px;
  font-weight: bold;
  color: #333;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
  letter-spacing: 2px;
}

.vertical-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  display: flex;
  justify-content: space-between;
  width: 80%;
}

.vertical-column {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.left-column {
  margin-right: 20%;
}

.right-column {
  margin-left: 20%;
}

.calligraphy-text {
  font-family: 'STXingkai', 'KaiTi', serif;
  font-size: 24px;
  color: #000;
  writing-mode: vertical-rl;
  text-orientation: mixed;
  letter-spacing: 2px;
  margin: 5px 0;
}

.offset-1 { transform: translateY(5px); }
.offset-2 { transform: translateY(10px); }
.offset-3 { transform: translateY(15px); }
.offset-4 { transform: translateY(20px); }

.swipe-tip {
  position: absolute;
  bottom: 15%;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #666;
}

.arrow {
  font-size: 20px;
  margin-bottom: 10px;
}

.tip-text {
  font-size: 14px;
  text-align: center;
  line-height: 1.5;
}