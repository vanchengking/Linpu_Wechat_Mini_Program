/* 全局变量与基础设置 */
page {
  background-color: #f7f7f7;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  color: #333;
  --primary-color: #8B2323; /* 传统朱红色 */
  --text-grey: #666;
  --bg-white: #fff;
}

.container {
  background-color: #f8f4e6;
  min-height: 100vh;
  padding: 20rpx;
}



.section-title {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0 30rpx;
}

.line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(to right, transparent, #d4cba7, transparent);
}

.section-title text {
  padding: 0 20rpx;
  font-size: 36rpx;
  color: #5d4b3c;
  font-weight: bold;
}

.building-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
  transition: transform 0.3s ease;
}

.card:hover {
  transform: translateY(-10rpx);
}

.card-swiper {
  width: 100%;
  aspect-ratio: 4/3; /* 4:3比例 */
}

.card-img {
  width: 100%;
  height: 100%;
  background-color: #eee;
}

.modal-swiper {
  width: 100%;
  aspect-ratio: 4/3; /* 4:3比例 */
}

.modal-img {
  width: 100%;
  height: 100%;
  background-color: #eee;
}

.card-info {
  padding: 25rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.card-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.card-tag {
  font-size: 24rpx;
  color: #d4cba7;
  background-color: #f8f4e6;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.card-summary {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
}

/* Modal styles */
.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s ease;
}

.detail-modal.show {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 80%;
  background: white;
  border-top-left-radius: 30rpx;
  border-top-right-radius: 30rpx;
  overflow: hidden;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.detail-modal.show .modal-content {
  transform: translateY(0);
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  font-size: 48rpx;
  color: #999;
  z-index: 1001;
}

.modal-scroll {
  height: 100%;
}

.modal-img {
  width: 100%;
  height: 350rpx;
  background-color: #eee;
}

.modal-body {
  padding: 30rpx;
}

.modal-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.modal-tags {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.tag {
  font-size: 24rpx;
  color: #d4cba7;
  background-color: #f8f4e6;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.tag.secondary {
  color: #7d6b5b;
  background-color: #e8e0c9;
}

.section {
  margin-bottom: 40rpx;
}

.label {
  font-size: 32rpx;
  font-weight: bold;
  color: #5d4b3c;
  margin-bottom: 15rpx;
  padding-bottom: 10rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}