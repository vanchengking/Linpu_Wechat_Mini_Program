/* 页面背景图 */
.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 页面背景设置 */
/*
page {
  background-color: transparent;
}
*/

/* 顶部内容 */
.header {
  width: 100%;
  position: relative;
  padding-top: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.title {
  text-align: center;
  font-size: 32rpx;
  color: #3c2a1e;
  font-weight: bold;
}

.avatar-box {
  display: flex;
  justify-content: center;
  margin-top: 10rpx;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background-color: #fcf7e3;
}

.subtitle {
  font-size: 32rpx;
  color: #fff;
  opacity: 0.95;
  letter-spacing: 2rpx;
  text-align: center;
  margin-top: 16rpx;
  font-weight: 500;
}

.points-badge {
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 28rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  margin-top: 14rpx;
  margin-bottom: 10rpx;
}

.points-badge text {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

/* 四个功能 */
.feature-row {
  margin-top: 40rpx;
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
}

.feature-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #3a2c1e;
}

/* 行走路线区域 */
.map-card {
  margin: 40rpx auto;
  width: 92%;
  background: #fffaf2;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.map-img {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
}

.map-title {
  font-size: 26rpx;
  margin-top: 12rpx;
  color: #3a2c1e;
}

/* 菜单 */
.menu {
  width: 92%;
  margin: 20rpx auto;
  padding-bottom: 120rpx; /* 为底部 tabBar 留出空间 */
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #d6c8a4;
  padding: 26rpx;
  border-radius: 12rpx;
  margin-bottom: 18rpx;
}

.left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.arrow {
  font-size: 34rpx;
  color: #5c4b36;
}

/* ========== 所获成就弹窗样式 ========== */
.ach-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.ach-popup {
  width: 100%;
  max-height: 80vh;
  background: #fffaf2;
  border-radius: 32rpx 32rpx 0 0;
  padding: 36rpx 30rpx 20rpx;
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.15);
  animation: slideUp 0.25s ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 标题栏 */
.ach-popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.ach-popup-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #3c2a1e;
}

.ach-close-btn {
  width: 56rpx;
  height: 56rpx;
  background: #e8ddd0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8a7a68;
}

/* 等级卡片 */
.ach-level-card {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(135deg, #d4a574, #b8895e);
  border-radius: 16rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 20rpx;
}

.ach-level-left {
  display: flex;
  align-items: center;
}

.ach-avatar-sm {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #fff;
  margin-right: 16rpx;
}

.ach-lv-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.ach-see-full text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

/* 数据概览 */
.ach-stats-row {
  display: flex;
  justify-content: space-around;
  background: #fef9ee;
  border-radius: 14rpx;
  padding: 20rpx 10rpx;
  margin-bottom: 20rpx;
}

.ach-stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ach-stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #d4883a;
}

.ach-stat-label {
  font-size: 21rpx;
  color: #8a7a68;
  margin-top: 4rpx;
}

/* 徽章区 */
.ach-badge-section {
  margin-bottom: 18rpx;
}

.ach-section-title {
  margin-bottom: 14rpx;
}

.ach-section-title text {
  font-size: 27rpx;
  font-weight: bold;
  color: #3c2a1e;
}

.ach-badge-row {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.ach-badge-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 14rpx 6rpx;
  background: #fdf6e8;
  border-radius: 12rpx;
  opacity: 1;
}

.ach-badge-item.ach-locked {
  opacity: 0.45;
}

.ach-b-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 6rpx;
}

.ach-badge-item text {
  font-size: 19rpx;
  color: #5a4a3a;
}

/* 成就列表 */
.ach-list-section {
  margin-bottom: 20rpx;
}

.ach-item {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #efe0cc;
}

.ach-item-name {
  width: 180rpx;
  font-size: 24rpx;
  color: #3c2a1e;
  flex-shrink: 0;
}

.ach-p-bar {
  flex: 1;
  height: 14rpx;
  background: #e8ddd0;
  border-radius: 7rpx;
  overflow: hidden;
  margin: 0 14rpx;
}

.ach-p-fill {
  height: 100%;
  background: linear-gradient(90deg, #e8a849, #d4883a);
  border-radius: 7rpx;
}

.ach-p-txt {
  font-size: 21rpx;
  color: #b08a50;
  flex-shrink: 0;
}

.ach-item.ach-done .ach-item-name {
  flex: 1;
  width: auto;
}

.ach-done-tag {
  font-size: 22rpx;
  color: #52c41a;
  font-weight: 500;
}

/* 底部按钮 */
.ach-bottom-btn {
  text-align: center;
  background: linear-gradient(135deg, #d4a574, #b8895e);
  padding: 22rpx 0;
  border-radius: 44rpx;
}

.ach-bottom-btn text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}


