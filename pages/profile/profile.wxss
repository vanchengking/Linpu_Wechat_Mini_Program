/* 页面背景图 */
.bg-image {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
}

/* 页面背景设置 */
/*
page {
  background-color: transparent;
}
*/

/* 顶部内容 */
.header {
  width: 100%;
  height: 200rpx;
  position: relative;
  padding-top: 20rpx;
}

.title {
  text-align: center;
  font-size: 32rpx;
  color: #3c2a1e;
  font-weight: bold;
}

.avatar-box {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
}

.avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background-color: #fcf7e3;
}

.subtitle {
  text-align: center;
  margin-top: 20rpx;
  margin-bottom: 15rpx;
  font-size: 26rpx;
  color: #4a3a2a;
}

/* 四个功能 */
.feature-row {
  margin-top: 70rpx;
  display: flex;
  justify-content: space-around;
  padding: 15rpx 0;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.feature-icon {
  width: 80rpx;
  height: 80rpx;
}

.feature-text {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #3a2c1e;
}

/* 行走路线区域 */
.map-card {
  margin: 40rpx auto;
  width: 92%;
  background: #fffaf2;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.map-img {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
}

.map-title {
  font-size: 26rpx;
  margin-top: 12rpx;
  color: #3a2c1e;
}

/* 菜单 */
.menu {
  width: 92%;
  margin: 20rpx auto;
  padding-bottom: 120rpx; /* 为底部 tabBar 留出空间 */
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #d6c8a4;
  padding: 26rpx;
  border-radius: 12rpx;
  margin-bottom: 18rpx;
}

.left {
  display: flex;
  align-items: center;
}

.menu-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.arrow {
  font-size: 34rpx;
  color: #5c4b36;
}


