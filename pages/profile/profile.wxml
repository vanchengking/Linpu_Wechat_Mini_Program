<image
  class="bg-image"
  src="https://bl.meishipay.com/images/background/background5.png"
  mode="aspectFill"
></image>

<view class="page">

  <!-- ====== 用户资料卡片（只读展示）====== -->
  <view class="profile-card">
    <view class="profile-header">
      <view class="avatar-wrapper">
        <image
          class="avatar"
          src="{{avatarUrl || defaultAvatar}}"
          mode="aspectFill"
        ></image>
      </view>
      <view class="profile-main">
        <text class="nickname-text">{{nickname || '未设置昵称'}}</text>
        <text class="level-text">Lv.{{level}} {{levelTitle}}</text>
        <text class="phone-text">{{phoneMasked}}</text>
      </view>
    </view>

    <!-- 手机号绑定按钮（唯一操作入口） -->
    <view class="action-row" wx:if="{{!phoneMasked || phoneMasked.indexOf('****') === -1}}">
      <button
        class="secondary-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        loading="{{bindingPhone}}"
      >
        绑定手机号
      </button>
    </view>
  </view>

  <!-- 积分/经验 -->
  <view class="summary-row">
    <view class="summary-card">
      <text class="summary-label">当前积分</text>
      <text class="summary-value">{{points}}</text>
    </view>
    <view class="summary-card">
      <text class="summary-label">累计经验</text>
      <text class="summary-value">{{totalExp}}</text>
    </view>
  </view>

  <!-- 云端统计 -->
  <view class="stats-card">
    <view class="section-title">云端统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{stats.landmarkVisited}}</text>
        <text class="stat-label">地标打卡</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.experienceDone}}</text>
        <text class="stat-label">文化体验</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{stats.arScanned}}</text>
        <text class="stat-label">AR 扫描</text>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="feature-row">
    <view class="feature-item" bindtap="goToLinpu">
      <image src="/resources/icons/云塔.png" class="feature-icon"></image>
      <text class="feature-text">林浦印象</text>
    </view>
    <view class="feature-item" bindtap="goToMapLandmark">
      <image src="/resources/icons/地标.png" class="feature-icon"></image>
      <text class="feature-text">地标打卡</text>
    </view>
    <view class="feature-item" bindtap="goToAchievement">
      <image src="/resources/icons/成就.png" class="feature-icon"></image>
      <text class="feature-text">成就中心</text>
    </view>
    <view class="feature-item" bindtap="goToRecord">
      <image src="/resources/icons/个人.png" class="feature-icon"></image>
      <text class="feature-text">个人记录</text>
    </view>
  </view>

  <!-- 菜单列表 -->
  <view class="menu">
    <view class="menu-item" bindtap="goToRanking">
      <view class="menu-left">
        <image src="/resources/icons/成就.png" class="menu-icon"></image>
        <text>排行榜</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <image src="/resources/icons/个人.png" class="menu-icon"></image>
        <text>更多设置</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToFeedback">
      <view class="menu-left">
        <image src="/resources/icons/地标.png" class="menu-icon"></image>
        <text>意见反馈</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToTeam">
      <view class="menu-left">
        <image src="/resources/icons/个人.png" class="menu-icon"></image>
        <text>研发团队</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <float-npc />
</view>