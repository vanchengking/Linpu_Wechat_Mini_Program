<image
  class="bg-image"
  src="https://bl.meishipay.com/images/background/background5.png"
  mode="aspectFill"
></image>

<view class="page">
  <view class="profile-card">
    <view class="profile-header">
      <button
        class="avatar-trigger"
        open-type="chooseAvatar"
        bindchooseavatar="onChooseAvatar"
        loading="{{uploadingAvatar}}"
      >
        <image class="avatar" src="{{profile.avatarUrl || defaultAvatar}}" mode="aspectFill"></image>
        <view class="avatar-mask">更换头像</view>
      </button>

      <view class="profile-main">
        <input
          class="nickname-input"
          value="{{editableNickname}}"
          maxlength="20"
          placeholder="请输入昵称"
          bindinput="onNicknameInput"
        />
        <text class="level-text">Lv.{{profile.level}} {{profile.levelTitle}}</text>
        <text class="phone-text">{{profile.phoneMasked || '未绑定手机号'}}</text>
        <text class="sync-text">{{syncText}}</text>
      </view>
    </view>

    <view class="action-row">
      <button class="primary-btn" bindtap="saveNickname" loading="{{savingNickname}}">
        保存昵称
      </button>
      <button
        class="secondary-btn"
        open-type="getPhoneNumber"
        bindgetphonenumber="onGetPhoneNumber"
        loading="{{bindingPhone}}"
      >
        {{profile.phone ? '更换手机号' : '绑定手机号'}}
      </button>
    </view>
  </view>

  <view class="summary-row">
    <view class="summary-card">
      <text class="summary-label">当前积分</text>
      <text class="summary-value">{{profile.points}}</text>
    </view>
    <view class="summary-card">
      <text class="summary-label">累计经验</text>
      <text class="summary-value">{{profile.totalExp}}</text>
    </view>
  </view>

  <view class="stats-card">
    <view class="section-title">云端统计</view>
    <view class="stats-grid">
      <view class="stat-item">
        <text class="stat-value">{{profile.stats.landmarkVisited}}</text>
        <text class="stat-label">地标打卡</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{profile.stats.experienceDone}}</text>
        <text class="stat-label">文化体验</text>
      </view>
      <view class="stat-item">
        <text class="stat-value">{{profile.stats.arScanned}}</text>
        <text class="stat-label">AR 扫描</text>
      </view>
    </view>
  </view>

  <view class="feature-row">
    <view class="feature-item" bindtap="goToLinpu">
      <image src="/resources/icons/云塔.png" class="feature-icon"></image>
      <text class="feature-text">林浦印象</text>
    </view>

    <view class="feature-item" bindtap="goToMapLandmark">
      <image src="/resources/icons/地标.png" class="feature-icon"></image>
      <text class="feature-text">地标打卡</text>
    </view>

    <view class="feature-item" bindtap="goToAchievement">
      <image src="/resources/icons/成就.png" class="feature-icon"></image>
      <text class="feature-text">成就中心</text>
    </view>

    <view class="feature-item" bindtap="goToRecord">
      <image src="/resources/icons/个人.png" class="feature-icon"></image>
      <text class="feature-text">个人记录</text>
    </view>
  </view>

  <view class="menu">
    <view class="menu-item" bindtap="goToRanking">
      <view class="menu-left">
        <image src="/resources/icons/成就.png" class="menu-icon"></image>
        <text>排行榜</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToSettings">
      <view class="menu-left">
        <image src="/resources/icons/个人.png" class="menu-icon"></image>
        <text>更多设置</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToFeedback">
      <view class="menu-left">
        <image src="/resources/icons/地标.png" class="menu-icon"></image>
        <text>意见反馈</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToTeam">
      <view class="menu-left">
        <image src="/resources/icons/个人.png" class="menu-icon"></image>
        <text>研发团队</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <float-npc />
</view>
