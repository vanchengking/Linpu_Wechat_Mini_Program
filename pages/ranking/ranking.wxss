/* ========== 排行榜页面样式 ========== */

page {
  background: linear-gradient(180deg, #fcf7e3 0%, #f5ead6 100%);
  min-height: 100vh;
}

.ranking-page {
  padding: 20rpx 0 0;
}

/* ========== 顶部标题 ========== */
.page-header {
  text-align: center;
  padding: 20rpx 30rpx 24rpx;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #3c2a1e;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8a7a68;
}

/* ========== 分类标签 ========== */
.tab-bar {
  display: flex;
  margin: 0 24rpx 24rpx;
  background: #fffaf2;
  border-radius: 14rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 10rpx rgba(160,130,90,0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #8a7a68;
  border-radius: 10rpx;
  transition: all 0.25s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #d4a574, #b8895e);
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(180,130,80,0.3);
}

/* ========== 领奖台 ========== */
.podium-section {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 20rpx 30rpx 0;
  margin-bottom: 28rpx;
  gap: 16rpx;
}

.podium-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  max-width: 220rpx;
}

.podium-item.first {
  order: 2;
}

.podium-item.second {
  order: 1;
}

.podium-item.third {
  order: 3;
}

.crown {
  font-size: 40rpx;
  margin-bottom: -10rpx;
  z-index: 1;
}

.podium-avatar-wrap {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  padding: 4rpx;
  margin-bottom: 8rpx;
}

.gold-ring { background: linear-gradient(135deg, #ffd700, #ffb300); }
.silver-ring { background: linear-gradient(135deg, #c0c0c0, #a0a0a0); }
.bronze-ring { background: linear-gradient(135deg, #cd7f32, #a0622e); }

.podium-avatar {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 3rpx solid #fffaf2;
}

.podium-rank {
  font-size: 24rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 4rpx;
}

.gold-text { color: #d4a017; }

.podium-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #3c2a1e;
  margin-bottom: 4rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 180rpx;
}

.podium-score {
  font-size: 22rpx;
  color: #b8895e;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.podium-bar {
  width: 100%;
  border-radius: 12rpx 12rpx 0 0;
}

.gold-bar {
  height: 120rpx;
  background: linear-gradient(180deg, #ffd700, #ffb300);
}

.silver-bar {
  height: 90rpx;
  background: linear-gradient(180deg, #d0d0d0, #b0b0b0);
}

.bronze-bar {
  height: 70rpx;
  background: linear-gradient(180deg, #cd7f32, #a0622e);
}

/* ========== 排行列表 ========== */
.rank-list-section {
  margin: 0 24rpx;
  background: #fffaf2;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(160,130,90,0.1);
}

.rank-list-header {
  margin-bottom: 18rpx;
  padding-bottom: 14rpx;
  border-bottom: 1rpx solid rgba(180,150,110,0.15);
}

.rank-list-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #3c2a1e;
}

.rank-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.rank-row {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-radius: 12rpx;
  background: #fef9ee;
}

.rank-row.me {
  background: linear-gradient(135deg, #fff8e1, #fdf6e8);
  border: 1rpx solid #e8d5a3;
  box-shadow: 0 2rpx 8rpx rgba(180,140,90,0.15);
}

.rank-pos {
  width: 50rpx;
  text-align: center;
  flex-shrink: 0;
}

.pos-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
}

.pos-text.top {
  color: #d4a574;
}

.rank-info {
  flex: 1;
  display: flex;
  align-items: center;
  margin-left: 8rpx;
  min-width: 0;
}

.rank-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 2rpx solid #efe0cc;
  flex-shrink: 0;
  margin-right: 14rpx;
}

.rank-detail {
  flex: 1;
  min-width: 0;
}

.rank-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #3c2a1e;
  margin-bottom: 4rpx;
}

.rank-level {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.lv-tag {
  font-size: 19rpx;
  color: #fff;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
}

.low { background: #95a5a6; }
.mid { background: #3498db; }
.high { background: #9b59b6; }
.top-lv { background: #e67e22; }

.rank-title-text {
  font-size: 20rpx;
  color: #8a7a68;
}

.rank-score-wrap {
  display: flex;
  align-items: baseline;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.rank-score {
  font-size: 30rpx;
  font-weight: bold;
  color: #d4a574;
}

.rank-score-unit {
  font-size: 20rpx;
  color: #b8895e;
  margin-left: 4rpx;
}

/* ========== 底部我的排名 ========== */
.my-rank-footer {
  margin: 24rpx 24rpx 0;
  text-align: center;
  padding: 22rpx;
  background: linear-gradient(135deg, #d4a574, #b8895e);
  border-radius: 16rpx;
}

.my-rank-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.my-rank-score {
  font-size: 23rpx;
  color: rgba(255,255,255,0.85);
}
