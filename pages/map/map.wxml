<view class="container">
  <view class="top-hint">
    <text>双指缩放地图，点击锚点查看地标</text>
  </view>

  <!-- 左上角底图缩略图 -->
  <view class="map-thumbnail">
    <image src="https://bl.meishipay.com/images/content/地图 (2).png" mode="aspectFill" class="thumbnail-img"></image>
  </view>

  <movable-area class="map-area" scale-area>
    <movable-view 
      class="map-view" 
      direction="all" 
      scale="true" 
      scale-min="0.25" 
      scale-max="4" 
      scale-value="{{scale}}"
      x="{{mapX}}"
      y="{{mapY}}"
      out-of-bounds="true"
    >
      <image src="https://bl.meishipay.com/images/content/地图 (2).png" class="map-bg"></image>
      
      <view 
        class="anchor-point" 
        wx:for="{{locations}}" 
        wx:key="id"
        style="left: {{item.left}}; top: {{item.top}};"
        bindtap="onAnchorTap"
        data-id="{{item.id}}"
      >
        <view class="pulse-ring"></view>
        <image src="/resources/icons/地标.png" class="anchor-icon"></image>
        <text class="anchor-label">{{item.name}}</text>
      </view>
    </movable-view>
  </movable-area>

  <view class="modal-wrapper {{showModal ? 'active' : ''}}">
    <view class="modal-backdrop" bindtap="closeModal"></view>
    <view class="modal-content">
      <view class="close-icon" bindtap="closeModal">✕</view>
      
      <scroll-view scroll-y class="modal-scroll">
        <view class="modal-content-inner">
          <view class="modal-top">
            <swiper class="modal-swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" duration="500">
              <block wx:for="{{activeLocation.images}}" wx:key="*this">
                <swiper-item>
                  <image class="swiper-image" src="{{item}}" mode="aspectFill"></image>
                </swiper-item>
              </block>
            </swiper>
          </view>
          
          <view class="modal-bottom">
            <view class="modal-body">
              <view class="modal-header">
                <text class="modal-title">{{activeLocation.name}}</text>
                <view class="modal-tags">
                  <text class="tag">{{activeLocation.type}}</text>
                </view>
              </view>
              
              <text class="modal-protection" wx:if="{{activeLocation.protectionLevel}}">{{activeLocation.protectionLevel}}</text>

              <view class="content-section">
                <view class="section-label">地标简介</view>
                <view class="desc-box">
                  <text class="section-text">{{activeLocation.intro || activeLocation.brief}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <button class="action-btn" bindtap="geoCheckIn">实地打卡</button>
        <button class="action-btn primary" bindtap="enterScene">进入场景探索</button>
      </view>
    </view>
  </view>

  <!-- 全局浮窗组件 -->
  <float-npc />
</view>