<view class="container">
  <view class="top-hint">
    <text>双指缩放探索 · 点击锚点进入</text>
  </view>

  <movable-area class="map-area" scale-area>
    <movable-view 
      class="map-view" 
      direction="all" 
      scale="{{true}}" 
      scale-min="0.8" 
      scale-max="3" 
      scale-value="{{scale}}"
    >
      <image class="map-bg" src="https://asave.rutno.com/fileview?id=CVAyXbX3RgJC" mode="widthFix"></image>

      <view 
        class="anchor-point" 
        wx:for="{{locations}}" 
        wx:key="id"
        style="left: {{item.left}}; top: {{item.top}};"
        bindtap="onAnchorTap"
        data-id="{{item.id}}"
      >
        <view class="pulse-ring"></view>
        <image class="anchor-icon" src="/resources/icons/地标.png"></image>
        <text class="anchor-label">{{item.name}}</text>
      </view>

    </movable-view>
  </movable-area>

  <view class="bottom-drawer {{showDrawer ? 'show' : ''}}">
    <view class="drawer-mask" bindtap="closeDrawer" wx:if="{{showDrawer}}"></view>
    
    <view class="drawer-content">
      <view class="drawer-header">
        <view>
          <text class="drawer-title">{{activeLocation.name}}</text>
          <text class="drawer-tag">{{activeLocation.type}}</text>
        </view>
        <view class="close-btn" bindtap="closeDrawer">×</view>
      </view>
      <view class="drawer-body">
        <text class="drawer-desc">{{activeLocation.brief}}</text>
      </view>
      <view class="drawer-footer">
        <button class="enter-btn" bindtap="enterScene">进入场景探索</button>
      </view>
    </view>
  </view>

</view>