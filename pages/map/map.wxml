<!--pages/map/map.wxml-->
<view class="container">
  <view class="header">
    <text class="subtitle">探索林浦地理风貌</text>
  </view>
  
  <view class="content">
    <view class="map-container">
      <image src="https://asave.rutno.com/fileview?id=CVAyXbX3RgJC" class="map-img"></image>
    </view>
    
    <view class="location-list">
      <view class="location-item" wx:for="{{locations}}" wx:key="id">
        <view class="location-icon">{{item.icon}}</view>
        <view class="location-info">
          <text class="location-name">{{item.name}}</text>
          <text class="location-category">{{item.category}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 全局浮窗聊天按钮 -->
  <view class="float-chat-btn" bindtap="goToChat">
    <image 
      src="https://asave.rutno.com/fileview?id=BMumLU82n7ZG"
      class="float-chat-icon"
    ></image>
  </view>

</view>