page {
  width: 100%;
  height: 100%;
  background-color: #000;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 顶部提示 */
.top-hint {
  position: absolute;
  top: 10rpx;
  width: 100%;
  text-align: center;
  z-index: 100;
  pointer-events: none;
}
.top-hint text {
  background: rgba(0, 0, 0, 0.6);
  color: #D4AF37;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  font-size: 20rpx;
  border: 1px solid rgba(212, 175, 55, 0.4);
}

/* 地图区域 */
.map-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #1a1a1a;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  z-index: 1;
}

.map-view {
  position: relative;
  width: 100%;
  max-width: 100%;
  max-height: 100%;
  aspect-ratio: 1356 / 744;
  background-color: #2a2a2a; /* 增加底色，防图片加载失败时全黑 */
}

.map-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  pointer-events: none;
}

/* ======= 锚点与呼吸灯特效 ======= */
.anchor-point {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.anchor-icon {
  width: 40rpx;
  height: 40rpx;
  position: relative;
  z-index: 2;
}

.anchor-label {
  margin-top: 6rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.pulse-ring {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  background-color: rgba(212, 175, 55, 0.6);
  border-radius: 50%;
  z-index: 1;
  animation: pulse 1.5s infinite ease-in-out;
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

/* ======= 中央悬浮窗 (VN 风格) ======= */
.modal-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  visibility: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s ease;
}

.modal-wrapper.active {
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(5px);
}

.modal-content {
  position: relative;
  width: 90%;
  height: 85%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  transform: scale(0.8);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
}

.modal-wrapper.active .modal-content {
  transform: scale(1);
  opacity: 1;
}

.close-icon {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  width: 50rpx;
  height: 50rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1001;
  font-size: 28rpx;
}

.modal-scroll {
  flex: 1;
  height: 0; /* 配合 flex 让 scroll-view 生效 */
}

/* 横版排布：左图右文 */
.modal-content-inner {
  display: flex;
  flex-direction: row;
  height: 100%;
}

.modal-left {
  width: 50%;
  height: 100%;
}

.modal-swiper {
  width: 100%;
  height: 100%;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.modal-right {
  width: 50%;
  display: flex;
  flex-direction: column;
  background-color: #fcf7e3; /* 与主色调呼应 */
}

.modal-body {
  padding: 30rpx 40rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-tags .tag {
  font-size: 20rpx;
  color: #8B2323;
  border: 1px solid #8B2323;
  padding: 4rpx 12rpx;
  border-radius: 30rpx;
}

.modal-protection {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.content-section {
  margin-top: 10rpx;
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.section-label {
  font-size: 26rpx;
  font-weight: bold;
  color: #5d4b3c;
  margin-bottom: 10rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #8B2323;
  flex-shrink: 0;
}

.desc-scroll {
  flex: 1;
  height: 0;
}

.section-text {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
}

.modal-footer {
  padding: 15rpx 40rpx 25rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
}

.action-btn {
  width: 45% !important;
  height: 70rpx;
  border-radius: 35rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  margin: 0;
  background: #f0f0f0;
  color: #333;
}

.action-btn.primary {
  background: #8B2323;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(139, 35, 35, 0.3);
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
