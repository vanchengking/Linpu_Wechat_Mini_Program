/* pages/map/map.wxss */
.container {
  min-height: 100vh;
  background: url('https://asave.rutno.com/fileview?id=S8JAJK5wKDye') no-repeat center center;
  background-size: cover;
  padding: 30rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 48rpx;
  color: black;
  font-weight: bold;
  display: block;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 32rpx;
  color: rgba(0, 0, 0, 0.8);
  display: block;
}

.map-container {
  background: white;
  border-radius: 20rpx;
  height: 400rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

.map-img {
  width: 100%;
  height: 100%;
  border: 10rpx solid #ffffff; /* 白色边框 */
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1); /* 阴影效果 */
  box-sizing: border-box;
}

.location-list {
  background: white;
  border-radius: 20rpx;
  padding: 0 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.location-item {
  display: flex;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.location-item:last-child {
  border-bottom: none;
}

.location-icon {
  font-size: 40rpx;
  margin-right: 30rpx;
}

.location-info {
  flex: 1;
}

.location-name {
  font-size: 32rpx;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.location-category {
  font-size: 24rpx;
  color: #666;
}