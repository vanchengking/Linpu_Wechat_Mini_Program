page {
  width: 100%;
  height: 100%;
  background-color: #000;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 顶部提示 */
.top-hint {
  position: absolute;
  top: 30rpx;
  width: 100%;
  text-align: center;
  z-index: 100;
  pointer-events: none;
}

.top-hint text {
  background: rgba(0, 0, 0, 0.6);
  color: #D4AF37;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  border: 1px solid rgba(212, 175, 55, 0.4);
}

/* 地图区域 */
.map-area {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: #1a1a1a;
  overflow: hidden;
  z-index: 1;
}

.map-view {
  position: relative;
  /* 保证地图铺满全屏且严格维持原图 1356:744 的比例 */
  width: max(100vw, calc(100vh * 1356 / 744));
  height: max(100vh, calc(100vw * 744 / 1356));
  background-color: #2a2a2a; 
}

.map-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: block;
  pointer-events: none;
}

/* ======= 锚点与呼吸灯特效 ======= */
.anchor-point {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.anchor-icon {
  width: 60rpx;
  height: 60rpx;
  position: relative;
  z-index: 2;
}

.anchor-label {
  margin-top: 6rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 20rpx;
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.pulse-ring {
  position: absolute;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(212, 175, 55, 0.6);
  border-radius: 50%;
  z-index: 1;
  animation: pulse 1.5s infinite ease-in-out;
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

/* ======= 中央悬浮窗 ======= */
/* ======= 中央悬浮窗 (上图下文版) ======= */
.modal-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  visibility: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s ease;
}

.modal-wrapper.active {
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(5px);
}

.modal-content {
  position: relative;
  width: 90%;
  height: 85%;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  transform: scale(0.8);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
}

.modal-wrapper.active .modal-content {
  transform: scale(1);
  opacity: 1;
}

.close-icon {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.4);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1001;
  font-size: 32rpx;
  backdrop-filter: blur(4px);
}

.modal-scroll {
  flex: 1;
  height: 0; 
}

/* 竖版排布容器 */
.modal-content-inner {
  display: flex;
  flex-direction: column;
  min-height: 100%;
  background-color: #fcf7e3; 
}

/* 顶部图片区域 */
.modal-top {
  width: 100%;
  height: 480rpx; /* 固定图片高度，更大气 */
  flex-shrink: 0;
}

.modal-swiper {
  width: 100%;
  height: 100%;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* 底部文字区域 */
.modal-bottom {
  width: 100%;
  display: flex;
  flex-direction: column;
  padding-bottom: 40rpx; /* 留出呼吸空间 */
}

.modal-body {
  padding: 40rpx 40rpx 0;
  display: flex;
  flex-direction: column;
}

/* 标题与标签：改为纵向排列 */
.modal-header {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.modal-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.modal-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.modal-tags .tag {
  font-size: 22rpx;
  color: #8B2323;
  border: 1px solid #8B2323;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
}

.modal-protection {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 30rpx;
}

.content-section {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
}

.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #5d4b3c;
  margin-bottom: 16rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #8B2323;
}

.section-text {
  font-size: 26rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

/* 底部按钮栏固定在最下方 */
.modal-footer {
  padding: 20rpx 40rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  justify-content: space-between;
}

.action-btn {
  width: 45% !important;
  height: 76rpx;
  border-radius: 38rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  font-weight: bold;
  margin: 0;
  background: #f0f0f0;
  color: #333;
}

.action-btn.primary {
  background: #8B2323;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(139, 35, 35, 0.25);
}

.action-btn:active {
  transform: scale(0.96);
  opacity: 0.9;
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

/* ======= 可自由拖拽浮窗聊天按钮 ======= */
.chat-drag-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  /* 关键：穿透全屏区域，不影响底层地图的点击和拖动 */
  pointer-events: none; 
  z-index: 9999;
}

.chat-drag-view {
  width: 120rpx;
  height: 120rpx;
  /* 关键：恢复图标本身的点击和拖拽属性 */
  pointer-events: auto; 
}

.float-chat-icon-drag {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.3);
  /* 继承你在 app.wxss 中写的呼吸悬浮动画 */
  animation: float 3s ease-in-out infinite; 
}