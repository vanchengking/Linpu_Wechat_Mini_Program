page {
  width: 100%;
  height: 100%;
  background-color: #000;
  overflow: hidden;
}

.container {
  width: 100%;
  height: 100%;
  position: relative;
}

/* 顶部提示 */
.top-hint {
  position: absolute;
  top: 60rpx;
  width: 100%;
  text-align: center;
  z-index: 100;
  pointer-events: none;
}
.top-hint text {
  background: rgba(0, 0, 0, 0.6);
  color: #D4AF37;
  padding: 10rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  border: 1px solid rgba(212, 175, 55, 0.4);
}

/* 拖拽地图区域 */
.map-area {
  width: 100vw;
  height: 100vh;
  background-color: #1a1a1a;
}

.map-view {
  width: 200vw;
  height: 200vh;
  display: flex;
  align-items: center;
  justify-content: center;
}

.map-bg {
  width: 100%;
  height: auto;
  pointer-events: none;
}

/* ======= 锚点与呼吸灯特效 ======= */
.anchor-point {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.anchor-icon {
  width: 60rpx;
  height: 60rpx;
  position: relative;
  z-index: 2;
}

.anchor-label {
  margin-top: 10rpx;
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  white-space: nowrap;
}

.pulse-ring {
  position: absolute;
  width: 50rpx;
  height: 50rpx;
  background-color: rgba(212, 175, 55, 0.6);
  border-radius: 50%;
  z-index: 1;
  animation: pulse 1.5s infinite ease-in-out;
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(2.5); opacity: 0; }
}

/* ======= 中央悬浮窗 (VN 风格) ======= */
.modal-wrapper {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1000;
  visibility: hidden;
  display: flex;
  justify-content: center;
  align-items: center;
  transition: all 0.3s ease;
}

.modal-wrapper.active {
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(5px);
}

.modal-content {
  position: relative;
  width: 85%;
  height: 70%;
  background: #fff;
  border-radius: 40rpx;
  overflow: hidden;
  transform: scale(0.8);
  opacity: 0;
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
}

.modal-wrapper.active .modal-content {
  transform: scale(1);
  opacity: 1;
}

.close-icon {
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1001;
  font-size: 32rpx;
}

.modal-scroll {
  flex: 1;
}

.modal-swiper {
  width: 100%;
  height: 400rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.modal-body {
  padding: 40rpx;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.modal-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.modal-tags .tag {
  font-size: 22rpx;
  color: #8B2323;
  border: 1px solid #8B2323;
  padding: 4rpx 16rpx;
  border-radius: 30rpx;
}

.modal-protection {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.content-section {
  margin-top: 30rpx;
}

.section-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #5d4b3c;
  margin-bottom: 15rpx;
  padding-left: 15rpx;
  border-left: 6rpx solid #8B2323;
}

.section-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

.modal-footer {
  padding: 30rpx 40rpx 40rpx;
  background: #fff;
}

.action-btn {
  width: 100% !important;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
}

.action-btn.primary {
  background: #8B2323;
  color: #fff;
  box-shadow: 0 10rpx 20rpx rgba(139, 35, 35, 0.3);
}

.action-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}
