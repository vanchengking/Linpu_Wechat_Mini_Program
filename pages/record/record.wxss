/* ========== 个人记录页面样式 ========== */

page {
  background: linear-gradient(180deg, #fcf7e3 0%, #f5ead6 100%);
  min-height: 100vh;
}

.record-page {
  padding: 0 0 20rpx;
}

/* ========== 顶部统计 ========== */
.stats-header {
  position: relative;
  background: linear-gradient(135deg, #d4a574 0%, #c49a6c 50%, #b8895e 100%);
  border-radius: 0 0 32rpx 32rpx;
  padding: 36rpx 30rpx 28rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.stats-header::after {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 220rpx;
  height: 220rpx;
  background: rgba(255,255,255,0.07);
  border-radius: 50%;
}

.stats-user {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.stats-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.6);
  background: #fff;
  margin-right: 18rpx;
}

.stats-meta {
  flex: 1;
}

.stats-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.stats-summary {
  font-size: 23rpx;
  color: rgba(255,255,255,0.8);
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255,255,255,0.15);
  border-radius: 16rpx;
  padding: 22rpx 10rpx;
  position: relative;
  z-index: 1;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 16rpx;
}

.stats-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  line-height: 1.2;
}

.stats-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

.stats-divider {
  width: 1rpx;
  height: 52rpx;
  background: rgba(255,255,255,0.25);
}

/* ========== 分类标签 ========== */
.tab-bar {
  display: flex;
  margin: 0 24rpx 20rpx;
  background: #fffaf2;
  border-radius: 14rpx;
  padding: 6rpx;
  box-shadow: 0 2rpx 10rpx rgba(160,130,90,0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: 26rpx;
  color: #8a7a68;
  border-radius: 10rpx;
  transition: all 0.25s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #d4a574, #b8895e);
  color: #fff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(180,130,80,0.3);
}

/* ========== 记录列表 ========== */
.record-list {
  padding: 0 24rpx;
}

.date-group {
  margin-bottom: 20rpx;
}

.date-label {
  display: block;
  font-size: 24rpx;
  color: #b8895e;
  font-weight: 500;
  margin-bottom: 12rpx;
  padding-left: 4rpx;
}

.record-card {
  display: flex;
  align-items: center;
  background: #fffaf2;
  border-radius: 16rpx;
  padding: 22rpx 20rpx;
  margin-bottom: 12rpx;
  box-shadow: 0 2rpx 10rpx rgba(160,130,90,0.08);
  border: 1rpx solid #efe0cc;
}

.record-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 18rpx;
  font-size: 30rpx;
}

.record-icon-wrap.landmark {
  background: #fff3e0;
}

.record-icon-wrap.experience {
  background: #f3e5f5;
}

.record-icon-wrap.scan {
  background: #e3f2fd;
}

.record-content {
  flex: 1;
  min-width: 0;
}

.record-title {
  display: block;
  font-size: 27rpx;
  font-weight: 600;
  color: #3c2a1e;
  margin-bottom: 4rpx;
}

.record-time {
  font-size: 22rpx;
  color: #8a7a68;
}

.record-tag {
  font-size: 20rpx;
  color: #b8895e;
  background: #fdf6e8;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 72rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #5a4a3a;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 23rpx;
  color: #b08a50;
}
