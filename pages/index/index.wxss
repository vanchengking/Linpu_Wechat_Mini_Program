/* 页面容器 */
.container {
  height: 100%;
  width: 100%;
  overflow: hidden;
  position: relative;
  background-color: #000; /* 背景先设黑，加载前不突兀 */
}

/* 全屏背景 */
.bg {
  position: absolute;
  width: 100%;
  height: 100%;
  z-index: 1; /* 提高层级，确保背景图在最底层但可见 */
  top: 0;
  left: 0;
  object-fit: cover;
}


/* 竖排文案区域（居中偏上） */
.vertical-text {
  position: absolute;
  top: 28%;
  width: 100%;
  display: flex;
  justify-content: center;
  flex-direction: row;
  z-index: 10; /* 确保竖排文字在背景图之上 */
}

/* 竖排文字列 */
.vertical-column {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.left-column {
  margin-right: 40rpx; /* 减少两列间距 */
  margin-top: -100rpx; /* 第一列向上偏移更多，错位更明显 */
}

.right-column {
  margin-left: 40rpx; /* 减少两列间距 */
  margin-top: 10rpx; /* 第二列向下偏移更多，错位更明显 */
}

/* 书法体文字样式 */
.calligraphy-text {
  font-family: 'Microsoft YaHei', '微软雅黑', sans-serif;
  font-size: 68rpx; /* 增大字号 */
  font-weight: bold; /* 加粗字体 */
  color: #333333; /* 深灰色 */
  text-shadow: 2rpx 2rpx 0 #ffffff; /* 白色描边，右下偏移 */
  line-height: 1.2;
  margin: 15rpx 0;
  opacity: 0.98;
  display: block;
  text-align: center;
}



/* 错位分布效果 */
.offset-1 {
  transform: translateY(8rpx);
}

.offset-2 {
  transform: translateY(16rpx);
}

.offset-3 {
  transform: translateY(24rpx);
}

.offset-4 {
  transform: translateY(32rpx);
}



/* 向上滑动提示 */
.swipe-tip {
  position: absolute;
  bottom: 120rpx;   /* 为导航栏保留空间 */
  width: 100%;
  text-align: center;
  color: #ffffff;
  text-shadow: 0 0 6rpx rgba(0,0,0,0.6);
  z-index: 10; /* 确保滑动提示在背景图之上 */
}

.arrow {
  font-size: 42rpx;
  margin-bottom: 10rpx;
}

.tabbar {
  position: fixed;
  bottom: 0;
  width: 100%;
  height: 200rpx;
  background: #fcf7e3;
  border-top: 1px solid #e5dabf;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.08);
  z-index: 10;
  padding-top: 15rpx; /* 增加内边距 */
}

