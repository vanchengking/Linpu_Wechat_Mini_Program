<view class="container">

  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="goHome">
    <text class="back-text">返回</text>
  </view>

  <!-- 全屏切换按钮 -->
  <view class="fullscreen-btn" bindtap="toggleFullscreen">
    <image 
      src="/resources/icons/全屏.png"
      class="fullscreen-icon"
    ></image>
  </view>

  <!-- 背景图 -->
  <image 
    class="bg-img"
    src="https://bl.meishipay.com/images/content/世公保1.jpg"
    mode="aspectFill"
  ></image>

  <!-- 场景选择按钮 -->
  <view class="scene-buttons">
    <view class="scene-btn" bindtap="selectScene" data-scene="濂江书院">
      <text class="scene-text">濂江书院</text>
    </view>
    <view class="scene-btn" bindtap="selectScene" data-scene="世公保">
      <text class="scene-text">世公保</text>
    </view>
    <view class="scene-btn" bindtap="selectScene" data-scene="泰山宫">
      <text class="scene-text">泰山宫</text>
    </view>
  </view>

  <!-- 尚书伯 -->
  <view wx:if="{{showCharacter}}" class="character-area">
    <image
      class="character"
      src="https://bl.meishipay.com/images/characters/尚书伯悬浮按钮.png"
      mode="widthFix"
      lazy-load
    ></image>
  </view>

  <!-- 历史消息容器（可滚动） -->
  <scroll-view 
    class="message-container" 
    scroll-y="true"
    scroll-top="{{scrollTop}}"
    bindscroll="onScroll"
  >
    <!-- 用户消息气泡列表 -->
    <view wx:for="{{messages}}" wx:key="index" class="message-item">
      <view wx:if="{{item.role === 'user'}}" class="user-bubble" animation="{{item.animation}}">
        <text>{{item.content}}</text>
      </view>
      <view wx:elif="{{item.role === 'ai'}}" class="ai-bubble" animation="{{item.animation}}">
        <text>{{item.content}}</text>
      </view>
    </view>

    <!-- 初始气泡 -->
    <view class="initial-bubble">
      <view class="bubble">
        <text>世公保全称世宫保尚书林公家庙，由明代林瀚始建，是 "三代五尚书" 家族的纪念地，木结构建筑群与 "形如乌纱" 的庙前水池，尽显闽派建筑特色与望族底蕴。</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部输入栏（全屏时隐藏） -->
  <view wx:if="{{!isFullscreen}}" class="input-bar">

    <!-- 输入框 -->
    <view class="input-wrapper">
      <input 
        class="input-box"
        placeholder="向尚书伯提问..."
        value="{{inputText}}"
        bindinput="onInput"
        bindconfirm="sendText"
      />
    </view>

    <!-- 语音按钮 -->
    <view class="voice-btn" bindtap="startVoice">
      <image 
        src="/resources/icons/语音输入.png"
        class="voice-icon"
      ></image>
    </view>

    <!-- 发送按钮 -->
    <view class="send-btn" bindtap="sendText">
      <text>发送</text>
    </view>

  </view>

</view>