<view class="experience-container">
  <!-- 背景图 -->
  <image class="bg-image" src="https://bl.meishipay.com/images/background/background5.png" mode="aspectFill"></image>
  
  <!-- 背景遮罩层 -->
  <view class="bg-overlay"></view>

  <view class="content-wrapper">
    <view class="section-header">
      <view class="title">文化解码</view>
      <view class="subtitle">沉浸式感受千年宋风遗韵</view>
    </view>

    <view class="grid-layout">
      <block wx:for="{{experiences}}" wx:key="id">
        <view class="experience-card" bindtap="showDetail" data-index="{{index}}" hover-class="card-hover">
          <view class="card-icon-box">
            <image class="card-icon" src="{{item.icon}}" mode="aspectFit" lazy-load></image>
          </view>
          <view class="card-label">{{item.title}}</view>
          <view class="card-tag">{{item.tag}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="modal-wrapper {{showModal ? 'active' : ''}}">
    <view class="modal-backdrop" bindtap="closeDetail"></view>
    <view class="modal-card">
      <view class="modal-header">
        <text class="modal-title">{{currentItem.title}}</text>
        <view class="close-icon" bindtap="closeDetail">✕</view>
      </view>
      
      <scroll-view scroll-y class="modal-scroll">
        <!-- 轮播图片容器 -->
        <view class="swiper-container" wx:if="{{currentItem.images && currentItem.images.length > 0}}">
          <swiper class="swiper" indicator-dots="{{true}}" autoplay="{{true}}" interval="3000" duration="500">
            <block wx:for="{{currentItem.images}}" wx:key="*this">
              <swiper-item>
                <image class="swiper-image" src="{{item}}" mode="aspectFill" lazy-load></image>
              </swiper-item>
            </block>
          </swiper>
        </view>
        
        <view class="content-block">
          <view class="block-label">渊源</view>
          <text class="block-text">{{currentItem.origin}}</text>
        </view>

        <view class="content-block">
          <view class="block-label">体验</view>
          <text class="block-text">{{currentItem.desc}}</text>
        </view>
      </scroll-view>

      <view class="modal-footer">
        <button class="action-btn" bindtap="closeDetail">了解了</button>
      </view>
    </view>
  </view>

  <!-- 全局浮窗组件 -->
  <float-npc />
</view>