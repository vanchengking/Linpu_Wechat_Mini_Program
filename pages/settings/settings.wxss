/* ========== 更多设置页面样式 ========== */

page {
  background: linear-gradient(180deg, #fcf7e3 0%, #f5ead6 100%);
  min-height: 100vh;
}

.settings-page {
  padding: 20rpx 24rpx 0;
}

/* ========== 用户信息卡片 ========== */
.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #d4a574 0%, #c49a6c 50%, #b8895e 100%);
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 30rpx rgba(180,140,90,0.35);
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(255,255,255,0.6);
  background: #fff;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 4rpx;
}

.user-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.85);
}

.edit-icon {
  font-size: 32rpx;
  color: rgba(255,255,255,0.7);
  padding: 10rpx;
}

/* ========== 区块 ========== */
.section {
  background: #fffaf2;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(160,130,90,0.1);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #3c2a1e;
  margin-bottom: 18rpx;
  padding-left: 4rpx;
}

/* ========== 设置列表 ========== */
.setting-list {
  display: flex;
  flex-direction: column;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 4rpx;
  border-bottom: 1rpx solid rgba(180,150,110,0.1);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-left {
  display: flex;
  align-items: center;
}

.setting-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.setting-label {
  font-size: 27rpx;
  color: #3c2a1e;
}

.setting-value {
  font-size: 24rpx;
  color: #8a7a68;
}

.arrow {
  font-size: 28rpx;
  color: #b8895e;
  padding: 4rpx 8rpx;
}

/* ========== 版本信息 ========== */
.version-info {
  text-align: center;
  padding: 32rpx 0 20rpx;
}

.version-text {
  display: block;
  font-size: 24rpx;
  color: #b8895e;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.version-desc {
  font-size: 22rpx;
  color: #8a7a68;
}

/* ========== 重置确认弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.55);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-box {
  width: 80%;
  background: #fffaf2;
  border-radius: 24rpx;
  padding: 40rpx 32rpx 28rpx;
  text-align: center;
  box-shadow: 0 12rpx 48rpx rgba(0,0,0,0.25);
}

.modal-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #3c2a1e;
  margin-bottom: 16rpx;
}

.modal-desc {
  display: block;
  font-size: 26rpx;
  color: #5a4a3a;
  line-height: 1.6;
  margin-bottom: 28rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
}

.modal-btn {
  flex: 1;
  padding: 18rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 27rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #e8ddd0;
  color: #5a4a3a;
}

.modal-btn.confirm {
  background: #e74c3c;
  color: #fff;
}

/* ========== 开发者模式彩蛋页面 ========== */
.easter-egg-page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: #fff;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ee-back-btn {
  position: absolute;
  top: 60rpx;
  left: 30rpx;
  width: 70rpx;
  height: 70rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ee-back-icon {
  font-size: 36rpx;
  color: #333;
}

.ee-image {
  width: 500rpx;
  height: 500rpx;
}

.ee-text {
  margin-top: 40rpx;
  font-size: 36rpx;
  color: #5d4b3c;
  font-weight: bold;
  letter-spacing: 2rpx;
}
