page {
  background-color: #fcf7e3;
  width: 100%;
  height: 100%;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 头部 Banner */
.header-banner {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.banner-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.7) 100%);
  z-index: 2;
}

.banner-text {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  z-index: 3;
  color: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 10rpx;
  display: block;
  letter-spacing: 2rpx;
}

/* 分类导航 */
.category-scroll {
  width: 100%;
  white-space: nowrap;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.category-list {
  display: flex;
  padding: 0 20rpx;
}

.category-item {
  position: relative;
  padding: 30rpx 40rpx;
  font-size: 30rpx;
  color: #6c6553;
  transition: all 0.3s;
}

.category-item.active {
  color: #8B2323;
  font-weight: bold;
  transform: scale(1.05);
}

.active-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #8B2323;
  border-radius: 6rpx;
}

/* 商品瀑布流 */
.product-scroll {
  flex: 1;
  background-color: #fcf7e3;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 20rpx;
}

.product-card {
  width: 48%;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: transform 0.2s;
}

.product-card:active {
  transform: scale(0.98);
}

.product-img {
  width: 100%;
  height: 340rpx;
  background-color: #eee;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #4a4035;
  font-weight: bold;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.product-desc {
  font-size: 22rpx;
  color: #8a8070;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-box {
  color: #e74c3c;
}

.currency {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
}

.sales-box {
  font-size: 20rpx;
  color: #b0a898;
}

.add-cart-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: #8B2323;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  line-height: 1;
  box-shadow: 0 4rpx 10rpx rgba(139, 35, 35, 0.4);
}

.add-cart-btn:active {
  background-color: #6b1a1a;
}

.bottom-placeholder {
  text-align: center;
  padding: 40rpx 0;
  color: #9a9080;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}
