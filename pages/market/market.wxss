page {
  background-color: #fcf7e3;
  width: 100%;
  height: 100%;
}

.container {
  width: 100%;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

/* 头部 Banner */
.header-banner {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.banner-img {
  width: 100%;
  height: 100%;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.banner-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.7) 100%);
  z-index: 2;
}

.banner-text {
  position: absolute;
  bottom: 40rpx;
  left: 40rpx;
  z-index: 3;
  color: #fff;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 10rpx;
  display: block;
  letter-spacing: 2rpx;
}

.floating-controls {
  position: fixed;
  bottom: 200rpx;
  right: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  z-index: 999;
}

.points-box {
  background: rgba(0,0,0,0.7);
  padding: 15rpx 30rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(212, 175, 55, 0.6);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.3);
  margin-bottom: 20rpx;
}

.cart-box {
  background: rgba(139, 35, 35, 0.9);
  padding: 15rpx 30rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.3);
  position: relative;
}

.cart-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

.cart-text {
  color: #fff;
  font-size: 26rpx;
  font-weight: bold;
}

.cart-badge {
  position: absolute;
  top: -10rpx;
  right: -5rpx;
  background-color: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 20rpx;
  border: 2rpx solid #fff;
}

.points-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 15rpx;
}

.points-num {
  color: #D4AF37;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.points-action {
  color: #fff;
  font-size: 26rpx;
  opacity: 0.9;
}

/* 分类导航 */
.category-scroll {
  width: 100%;
  white-space: nowrap;
  background-color: #fff;
  border-bottom: 1rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.category-list {
  display: flex;
  padding: 0 20rpx;
}

.category-item {
  position: relative;
  padding: 30rpx 40rpx;
  font-size: 30rpx;
  color: #6c6553;
  transition: all 0.3s;
}

.category-item.active {
  color: #8B2323;
  font-weight: bold;
  transform: scale(1.05);
}

.active-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background-color: #8B2323;
  border-radius: 6rpx;
}

/* 商品瀑布流 */
.product-scroll {
  flex: 1;
  background-color: #fcf7e3;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  padding: 20rpx;
}

.product-card {
  width: 48%;
  background: #fff;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: transform 0.2s;
}

.product-card:active {
  transform: scale(0.98);
}

.product-img {
  width: 100%;
  height: 340rpx;
  background-color: #eee;
}

.product-info {
  padding: 20rpx;
}

.product-name {
  font-size: 28rpx;
  color: #4a4035;
  font-weight: bold;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.product-desc {
  font-size: 22rpx;
  color: #8a8070;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.product-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price-box {
  color: #e74c3c;
}

.currency {
  font-size: 20rpx;
  margin-right: 4rpx;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
}

.sales-box {
  font-size: 20rpx;
  color: #b0a898;
}

/* ========== 数量选择器 ========== */
.qty-selector {
  position: absolute;
  right: 16rpx;
  bottom: 20rpx;
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 30rpx;
  border: 2rpx solid #8B2323;
  overflow: hidden;
  box-shadow: 0 4rpx 10rpx rgba(139, 35, 35, 0.2);
}

.qty-btn {
  width: 52rpx;
  height: 52rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #8B2323;
  background-color: #fff;
  transition: all 0.15s;
}

.qty-btn:active:not(.disabled) {
  background-color: #8B2323;
  color: #fff;
}

.qty-minus {
  border-right: 2rpx solid #eee;
}

.qty-plus {
  border-left: 2rpx solid #eee;
}

.qty-num {
  min-width: 56rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #8B2323;
  line-height: 52rpx;
}

.add-cart-btn {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 50rpx;
  height: 50rpx;
  background-color: #8B2323;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 40rpx;
  line-height: 1;
  box-shadow: 0 4rpx 10rpx rgba(139, 35, 35, 0.4);
}

.add-cart-btn:active {
  background-color: #6b1a1a;
}

.bottom-placeholder {
  text-align: center;
  padding: 40rpx 0;
  color: #9a9080;
  font-size: 24rpx;
  letter-spacing: 2rpx;
}

/* 积分兑换弹窗 */
.coupon-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  z-index: 1000;
  visibility: hidden;
  opacity: 0;
  transition: all 0.3s;
  display: flex;
  justify-content: center;
  align-items: center;
}

.coupon-modal.active {
  visibility: visible;
  opacity: 1;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
}

.coupon-modal .modal-content {
  position: relative;
  width: 80%;
  max-height: 70%;
  background: #fcf7e3;
  border-radius: 20rpx;
  z-index: 1001;
  display: flex;
  flex-direction: column;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.2);
}

.coupon-modal .modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #eee;
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
}

.coupon-modal .modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.coupon-modal .close-btn {
  font-size: 40rpx;
  color: #999;
  line-height: 1;
  padding: 10rpx;
}

.modal-points-info {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  text-align: center;
}

.modal-points-info .highlight {
  color: #8B2323;
  font-size: 36rpx;
  font-weight: bold;
  margin-left: 10rpx;
}

.coupon-list {
  flex: 1;
  height: 400rpx;
}

.coupon-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
}

.coupon-left {
  display: flex;
  flex-direction: column;
}

.coupon-discount {
  font-size: 36rpx;
  font-weight: bold;
  color: #e74c3c;
  margin-bottom: 10rpx;
  white-space: pre-line;
}

.coupon-desc {
  font-size: 22rpx;
  color: #999;
}

.coupon-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.coupon-cost {
  font-size: 24rpx;
  color: #8B2323;
  margin-bottom: 15rpx;
}

.exchange-btn {
  margin: 0;
  padding: 0 30rpx !important;
  height: 50rpx;
  line-height: 50rpx;
  font-size: 24rpx;
  background: #8B2323;
  color: #fff;
  border-radius: 25rpx;
}

.exchange-btn[disabled] {
  background: #ccc !important;
  color: #fff !important;
}
