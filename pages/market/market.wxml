<view class="container">
  <!-- 悬浮功能区 -->
  <view class="floating-controls">
    <!-- 积分悬浮窗 -->
    <view class="points-box" bindtap="openCouponModal">
      <image src="/resources/icons/云塔.png" class="points-icon"></image>
      <text class="points-num">{{userPoints}} 积分</text>
      <text class="points-action">兑换 > </text>
    </view>
    
    <!-- 购物车悬浮窗 -->
    <view class="cart-box" bindtap="goToCart">
      <view class="cart-badge" wx:if="{{cartCount > 0}}">{{cartCount}}</view>
      <image src="/resources/icons/成就.png" class="cart-icon"></image>
      <text class="cart-text">购物车</text>
    </view>
  </view>

  <!-- 分类导航 -->
  <scroll-view scroll-x class="category-scroll" scroll-with-animation>
    <view class="category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="id"
        class="category-item {{currentTab === item.id ? 'active' : ''}}"
        bindtap="switchTab"
        data-id="{{item.id}}"
      >
        <text>{{item.name}}</text>
        <view class="active-line" wx:if="{{currentTab === item.id}}"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 商品瀑布流 -->
  <scroll-view scroll-y class="product-scroll">
    <view class="product-grid">
      <view 
        class="product-card" 
        wx:for="{{filteredProducts}}" 
        wx:key="id"
        bindtap="viewDetail"
        data-id="{{item.id}}"
      >
        <image src="{{item.image}}" mode="aspectFill" class="product-img"></image>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.desc}}</text>
          
          <view class="product-bottom">
            <view class="price-box">
              <text class="currency">¥</text>
              <text class="price">{{item.price}}</text>
            </view>
            <view class="sales-box">已售 {{item.sales}}</view>
          </view>
        </view>
        
        <!-- 悬浮购物车按钮 -->
        <view class="add-cart-btn" catchtap="addToCart" data-id="{{item.id}}">
          +
        </view>
      </view>
    </view>
    
    <!-- 底部占位 -->
    <view class="bottom-placeholder">
      <text>- 传承文化，生生不息 -</text>
    </view>
  </scroll-view>

  <!-- 积分兑换弹窗 -->
  <view class="coupon-modal {{showCouponModal ? 'active' : ''}}">
    <view class="modal-mask" bindtap="closeCouponModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">积分兑换抵用券</text>
        <view class="close-btn" bindtap="closeCouponModal">×</view>
      </view>
      <view class="modal-points-info">
        <text>当前积分余额：</text>
        <text class="highlight">{{userPoints}}</text>
      </view>
      <scroll-view scroll-y class="coupon-list">
        <view class="coupon-item" wx:for="{{coupons}}" wx:key="id">
          <view class="coupon-left">
            <text class="coupon-discount">{{item.discountText}}</text>
            <text class="coupon-desc">全场通用</text>
          </view>
          <view class="coupon-right">
            <text class="coupon-cost">{{item.cost}} 积分</text>
            <button class="exchange-btn" bindtap="exchangeCoupon" data-id="{{item.id}}" disabled="{{userPoints < item.cost}}">兑换</button>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>
</view>