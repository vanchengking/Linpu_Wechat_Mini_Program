<view class="container">
  <!-- 头部 Banner -->
  <view class="header-banner">
    <image src="https://101.34.247.48:8888/down/ScTxYTX9VGGK.png" mode="aspectFill" class="banner-img"></image>
    <view class="banner-mask"></view>
    <view class="banner-text">
      <text class="title">林浦市集</text>
      <text class="subtitle">千年古风，掌中把玩</text>
    </view>
  </view>

  <!-- 分类导航 -->
  <scroll-view scroll-x class="category-scroll" scroll-with-animation>
    <view class="category-list">
      <view 
        wx:for="{{categories}}" 
        wx:key="id"
        class="category-item {{currentTab === item.id ? 'active' : ''}}"
        bindtap="switchTab"
        data-id="{{item.id}}"
      >
        <text>{{item.name}}</text>
        <view class="active-line" wx:if="{{currentTab === item.id}}"></view>
      </view>
    </view>
  </scroll-view>

  <!-- 商品瀑布流 -->
  <scroll-view scroll-y class="product-scroll">
    <view class="product-grid">
      <view 
        class="product-card" 
        wx:for="{{filteredProducts}}" 
        wx:key="id"
        bindtap="viewDetail"
        data-id="{{item.id}}"
      >
        <image src="{{item.image}}" mode="aspectFill" class="product-img"></image>
        <view class="product-info">
          <text class="product-name">{{item.name}}</text>
          <text class="product-desc">{{item.desc}}</text>
          
          <view class="product-bottom">
            <view class="price-box">
              <text class="currency">¥</text>
              <text class="price">{{item.price}}</text>
            </view>
            <view class="sales-box">已售 {{item.sales}}</view>
          </view>
        </view>
        
        <!-- 悬浮购物车按钮 -->
        <view class="add-cart-btn" catchtap="addToCart" data-id="{{item.id}}">
          +
        </view>
      </view>
    </view>
    
    <!-- 底部占位 -->
    <view class="bottom-placeholder">
      <text>- 传承文化，生生不息 -</text>
    </view>
  </scroll-view>
</view>