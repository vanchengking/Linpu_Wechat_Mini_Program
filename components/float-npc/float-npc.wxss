/* 覆盖全屏，必须设置 pointer-events: none，否则底下的页面点不到了！ */
.movable-area {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: calc(100vh - 120rpx);
  pointer-events: none;
  z-index: 99999;
  bottom: 120rpx;
}

/* 拖拽块 */
.movable-view {
  width: 90rpx;
  height: 90rpx;
  pointer-events: auto; /* 关键：让图标本身可以被点击和拖拽 */
  display: flex;
  justify-content: center;
  align-items: center;
  overflow: visible;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.92);
  border: 3rpx solid rgba(212, 165, 116, 0.85);
  box-shadow: 0 4rpx 16rpx rgba(180, 130, 80, 0.35);
}

/* NPC 图标（严格限制在圆形容器内） */
.npc-icon {
  width: 70rpx;
  height: 70rpx;
  z-index: 2;
}

/* 背景呼吸灯特效（增加AI灵动感） */
.pulse-ring {
  position: absolute;
  width: 90rpx;
  height: 90rpx;
  background-color: rgba(212, 175, 55, 0.5);
  border-radius: 50%;
  z-index: 1;
  animation: pulse 2s infinite ease-in-out;
}

@keyframes pulse {
  0% { transform: scale(1); opacity: 0.8; }
  100% { transform: scale(1.6); opacity: 0; }
}