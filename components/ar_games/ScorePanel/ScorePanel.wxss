.score-panel {
  background: rgba(0, 0, 0, 0.55);
  padding: 6px 10px 5px;
  border-radius: 10px;
  color: #fff;
  z-index: 100;
  min-width: 76px;
  display: flex;
  flex-direction: column;
  gap: 3px;
  backdrop-filter: blur(4px);
  border: 1px solid rgba(255, 215, 0, 0.25);
}

.score-container, .timer-container {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.score-label, .time-label {
  font-size: 10px;
  margin-right: 6px;
  color: rgba(255, 255, 255, 0.75);
}

.score-value, .time-value {
  font-size: 13px;
  font-weight: bold;
  color: #FFD700;
}

.combo-container {
  background: linear-gradient(90deg, #FF4500, #FF8C00);
  padding: 2px 8px;
  border-radius: 10px;
  text-align: center;
}

.combo-text {
  font-size: 12px;
  font-weight: bold;
  color: #fff;
  font-style: italic;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.animate-bounce {
  animation: bounce 0.3s ease;
}

.end-hint-container {
  margin-top: 2px;
}

.end-hint-text {
  font-size: 10px;
  color: rgba(255, 255, 255, 0.6);
  font-style: italic;
}
